# ─── SESSION ──────────────────────────────────────────────────────
# Clé secrète pour signer les cookies JWT (mettre une valeur aléatoire longue)
SESSION_SECRET=changez-cette-valeur-en-production

# ─── STRIPE ───────────────────────────────────────────────────────
# Clés disponibles sur https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
PUBLIC_STRIPE_KEY=pk_live_...

# Webhook secret — obtenu via : stripe listen --forward-to localhost:4321/api/stripe/webhook
# En production : Stripe Dashboard → Developers → Webhooks → votre endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── SMTP (envoi d'e-mails) ────────────────────────────────────────
# Paramètres fournis par votre hébergeur (OVH, Infomaniak, Ionos, etc.)
SMTP_HOST=mail.votre-domaine.fr
SMTP_PORT=465
SMTP_USER=noreply@jcbo-conseil.fr
SMTP_PASS=votre_mot_de_passe_smtp
FROM_EMAIL=JCBO Conseil <noreply@jcbo-conseil.fr>

# ─── SUPABASE ─────────────────────────────────────────────────────
# Disponibles sur https://supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
