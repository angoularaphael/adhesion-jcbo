---
import AdherentLayout from "../../layouts/AdherentLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import { mockRessources } from "../../data/mock";

const variantByCategorie: Record<string, "or" | "vert" | "gris"> = {
  Guide: "or",
  Modèle: "vert",
  Outil: "gris",
};
---

<AdherentLayout titre="Ressources">

  <div class="mb-8">
    <h2 class="text-2xl font-bold" style="color: #0D1B2A;">Ressources</h2>
    <p class="text-sm text-gray-500 mt-1">Documents et outils mis à disposition par JCBO Conseil.</p>
  </div>

  <Card>
    <div class="flex flex-col divide-y divide-gray-100">
      {mockRessources.map((r) => (
        <div class="flex items-center justify-between py-4 first:pt-0 last:pb-0">
          <div class="flex items-center gap-4">
            <!-- Icône -->
            <div
              class="w-10 h-10 rounded-lg flex items-center justify-center text-base flex-shrink-0"
              style="background-color: rgba(201,168,76,0.1);"
            >
              📄
            </div>
            <div>
              <p class="text-sm font-medium" style="color: #0D1B2A;">{r.titre}</p>
              <p class="text-xs text-gray-400 mt-0.5">
                {new Date(r.date).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              </p>
            </div>
          </div>

          <div class="flex items-center gap-3">
            <Badge variant={variantByCategorie[r.categorie] ?? "gris"}>{r.categorie}</Badge>
            <a
              href={r.fichier}
              class="text-xs font-semibold px-3 py-1.5 rounded-lg transition hover:opacity-80"
              style="background-color: #0D1B2A; color: white;"
            >
              Télécharger
            </a>
          </div>
        </div>
      ))}
    </div>
  </Card>

</AdherentLayout>
