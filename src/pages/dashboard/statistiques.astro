---
import AdherentLayout from "../../layouts/AdherentLayout.astro";
import { getStats } from "../../lib/store";

const stats = await getStats();
const progression = stats.progressionMensuelle?.length
  ? stats.progressionMensuelle
  : [{ mois: "—", valeur: 0 }];
const max = Math.max(...progression.map((p) => p.valeur), 1);

const kpis = [
  { label: "Total adhérents", value: stats.totalAdherents },
  { label: "Adhérents actifs", value: stats.adherentsActifs },
  { label: "Nouveaux ce mois", value: `+${stats.nouveauxCeMois}`, gold: true },
  { label: "Taux renouvellement", value: `${stats.tauxRenouvellement}%` },
  { label: "CA ce mois (€)", value: Math.round(stats.caMois ?? 0) },
  { label: "Diagnostics reçus", value: stats.diagnosticsRecus ?? 0 },
  { label: "Messages non lus", value: stats.messagesNonLus ?? 0 },
  { label: "Inscriptions cours", value: stats.inscriptionsCours ?? 0 },
];
---

<AdherentLayout titre="Statistiques">

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    {kpis.map((k) => (
      <div class="bg-white rounded-xl p-4 sm:p-6 shadow-sm" style="border: 1px solid #f1f3f5;">
        <p class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-3">{k.label}</p>
        <p class="text-2xl sm:text-3xl font-bold" style={k.gold ? "color: #d4a762;" : "color: #0b1f3a;"}>{k.value}</p>
      </div>
    ))}
  </div>

  <div class="bg-white rounded-xl shadow-sm p-6 lg:p-8" style="border: 1px solid #f1f3f5;">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-base font-semibold" style="color: #0b1f3a;">Nouvelles adhésions par mois</h2>
        <p class="text-xs text-gray-400 mt-0.5">6 derniers mois</p>
      </div>
    </div>

    <div class="flex items-end gap-3 lg:gap-6 px-4" style="height: 200px;">
      {progression.map((p) => (
        <div class="flex flex-col items-center gap-2 flex-1">
          <span class="text-xs font-semibold" style="color: #0b1f3a;">{p.valeur}</span>
          <div class="w-full rounded-t-lg transition-all duration-500 hover:opacity-80" style={`height: ${Math.round((p.valeur / max) * 160)}px; background: linear-gradient(180deg, #d4a762 0%, #0b1f3a 100%); min-height: 4px;`}></div>
          <span class="text-xs text-gray-400 font-medium">{p.mois}</span>
        </div>
      ))}
    </div>
  </div>

</AdherentLayout>
