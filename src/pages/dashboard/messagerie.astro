---
import AdherentLayout from "../../layouts/AdherentLayout.astro";
import { getConversations } from "../../lib/store";

const conversations = await getConversations();
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? "";
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "";
---

<AdherentLayout titre="Messagerie">

  <div class="flex gap-4 h-[calc(100svh-6rem)] lg:h-[calc(100svh-10rem)]">

    <!-- Liste des conversations -->
    <div id="conv-sidebar" class="w-full lg:w-80 flex-shrink-0 bg-white rounded-xl shadow-sm flex flex-col overflow-hidden lg:flex">
      <div class="px-4 py-3 border-b border-gray-100">
        <p class="text-sm font-semibold" style="color: #0b1f3a;">Conversations</p>
      </div>
      <div id="conv-list" class="flex-1 overflow-y-auto divide-y divide-gray-100">
        {conversations.map((c, i) => (
          <button
            data-id={c.id}
            class={`conv-item w-full text-left px-4 py-3 hover:bg-gray-50 transition-colors ${i === 0 ? "bg-gray-50" : ""}`}
          >
            <div class="flex items-start justify-between gap-2">
              <div class="min-w-0">
                <p class="text-sm font-semibold truncate" style="color: #0b1f3a;">{c.adherent}</p>
                <p class="text-xs text-gray-400 truncate">{c.sujet}</p>
                <p class="text-xs text-gray-400 mt-1 truncate">{c.dernier_message}</p>
              </div>
              <div class="flex flex-col items-end gap-1 flex-shrink-0">
                <span class="text-xs text-gray-300">{c.date}</span>
                {c.non_lu > 0 && (
                  <span class="non-lu-badge w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold text-white" style="background-color: #d4a762;">{c.non_lu}</span>
                )}
              </div>
            </div>
          </button>
        ))}
      </div>
    </div>

    <!-- Zone de conversation active -->
    <div id="conv-main" class="hidden lg:flex flex-1 bg-white rounded-xl shadow-sm flex-col overflow-hidden">

      <!-- En-tête conversation -->
      <div id="conv-header" class="px-6 py-4 border-b border-gray-100 flex items-center">
        <button id="btn-back" class="lg:hidden mr-3 p-1.5 rounded-lg hover:bg-gray-100 transition flex-shrink-0" style="color: #0b1f3a;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <div>
          <p id="conv-nom" class="text-sm font-semibold" style="color: #0b1f3a;"></p>
          <p id="conv-sujet" class="text-xs text-gray-400"></p>
        </div>
      </div>

      <!-- Messages -->
      <div id="conv-messages" class="flex-1 overflow-y-auto px-6 py-4 flex flex-col gap-3">
      </div>

      <!-- Zone de saisie -->
      <div class="px-6 py-4 border-t border-gray-100 flex gap-3">
        <input
          id="msg-input"
          type="text"
          placeholder="Écrire un message…"
          class="flex-1 border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762]"
          style="color: #0b1f3a;"
        />
        <button
          id="msg-send"
          class="px-4 py-2.5 rounded-full text-sm font-semibold text-white transition hover:opacity-90 flex-shrink-0 disabled:opacity-50"
          style="background-color: #0b1f3a;"
        >
          Envoyer
        </button>
      </div>

    </div>

  </div>

  <script is:inline define:vars={{ conversations }}>
    let activeId = conversations[0]?.id ?? null;

    function renderMessages(id) {
      const conv = conversations.find((c) => c.id === id);
      if (!conv) return;

      document.getElementById("conv-nom").textContent = conv.adherent;
      document.getElementById("conv-sujet").textContent = conv.sujet;

      const zone = document.getElementById("conv-messages");
      zone.innerHTML = conv.messages.map((m) => {
        const isAdmin = m.de === "admin";
        return `
          <div class="flex items-end gap-2 ${isAdmin ? "justify-end" : "justify-start"}">
            ${!isAdmin ? `<div class="w-7 h-7 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 mb-1" style="background-color: #0b1f3a;">${conv.adherent.split(" ").map(n => n[0]).join("").slice(0,2)}</div>` : ""}
            <div class="max-w-[75%] sm:max-w-xs lg:max-w-sm">
              <div class="px-4 py-3 text-sm leading-relaxed shadow-sm ${
                isAdmin ? "rounded-2xl rounded-br-sm text-white" : "rounded-2xl rounded-bl-sm bg-gray-100"
              }" style="${isAdmin ? "background-color: #0b1f3a;" : "color: #0b1f3a;"}">
                ${m.texte}
              </div>
              <p class="text-xs mt-1 ${isAdmin ? "text-right" : ""} text-gray-400 px-1">${m.heure}</p>
            </div>
            ${isAdmin ? `<div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mb-5" style="background-color: rgba(212,167,98,0.15); color: #d4a762;">SA</div>` : ""}
          </div>
        `;
      }).join("");
      zone.scrollTop = zone.scrollHeight;
    }

    function markAsRead(id) {
      fetch("/api/messagerie", {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ conversationId: id }),
      });
      const conv = conversations.find(c => c.id === id);
      if (conv) conv.non_lu = 0;
      document.querySelectorAll(".conv-item").forEach(btn => {
        if (btn.dataset.id === id) {
          const badge = btn.querySelector(".non-lu-badge");
          if (badge) badge.remove();
        }
      });
    }

    const sidebar = document.getElementById("conv-sidebar");
    const convMain = document.getElementById("conv-main");

    function showConversation(id) {
      activeId = id;
      renderMessages(id);
      markAsRead(id);
      if (window.innerWidth < 1024) {
        sidebar.classList.add("hidden");
        convMain.classList.remove("hidden");
        convMain.classList.add("flex");
      }
    }

    document.getElementById("btn-back")?.addEventListener("click", () => {
      convMain.classList.add("hidden");
      convMain.classList.remove("flex");
      sidebar.classList.remove("hidden");
    });

    document.querySelectorAll(".conv-item").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".conv-item").forEach((b) => b.classList.remove("bg-gray-50"));
        btn.classList.add("bg-gray-50");
        showConversation(btn.dataset.id);
      });
    });

    async function sendMessage() {
      const input = document.getElementById("msg-input");
      const sendBtn = document.getElementById("msg-send");
      const text = input.value.trim();
      if (!text || !activeId) return;

      sendBtn.disabled = true;
      input.disabled = true;

      const res = await fetch("/api/messagerie", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ texte: text, conversationId: activeId }),
      });

      if (res.ok) {
        const msg = await res.json();
        const conv = conversations.find(c => c.id === activeId);
        if (conv) {
          conv.messages.push(msg);
          conv.dernier_message = text;
        }
        input.value = "";
        renderMessages(activeId);
      }

      sendBtn.disabled = false;
      input.disabled = false;
      input.focus();
    }

    document.getElementById("msg-send").addEventListener("click", sendMessage);
    document.getElementById("msg-input").addEventListener("keydown", (e) => {
      if (e.key === "Enter") sendMessage();
    });

    if (window.innerWidth >= 1024 && activeId) {
      renderMessages(activeId);
      markAsRead(activeId);
    }

    window.addEventListener("jcbo:new-message", async () => {
      const res = await fetch("/api/messagerie");
      if (res.ok) location.reload();
    });
  </script>
  {supabaseUrl && supabaseAnonKey && (
    <>
      <script is:inline define:vars={{ supabaseUrl, supabaseAnonKey }}>
        window.__JCBO_REALTIME__ = { url: supabaseUrl, anonKey: supabaseAnonKey };
      </script>
      <script src="/js/realtime-messaging.js" defer></script>
    </>
  )}

</AdherentLayout>
