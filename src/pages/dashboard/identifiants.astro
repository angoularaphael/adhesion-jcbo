---
import AdherentLayout from "../../layouts/AdherentLayout.astro";
import Badge from "../../components/ui/Badge.astro";
import { mockIdentifiants } from "../../data/mock";
---

<AdherentLayout titre="Identifiants">

  <div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-400">{mockIdentifiants.length} accès générés</p>
    <button id="btn-generer"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold text-white transition-all duration-200 hover:opacity-90 active:scale-[0.98]"
      style="background-color: #0b1f3a;">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Générer un accès
    </button>
  </div>

  <div class="bg-white rounded-xl shadow-sm overflow-hidden" style="border: 1px solid #f1f3f5;">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr style="border-bottom: 1px solid #f1f3f5; background-color: #fafafa;">
            <th class="text-left text-xs font-medium text-gray-400 uppercase tracking-widest px-6 py-4">ID</th>
            <th class="text-left text-xs font-medium text-gray-400 uppercase tracking-widest px-6 py-4">Nom</th>
            <th class="text-left text-xs font-medium text-gray-400 uppercase tracking-widest px-6 py-4">E-mail</th>
            <th class="text-left text-xs font-medium text-gray-400 uppercase tracking-widest px-6 py-4">Créé le</th>
            <th class="text-left text-xs font-medium text-gray-400 uppercase tracking-widest px-6 py-4">Statut</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          {mockIdentifiants.map((item) => (
            <tr class="hover:bg-gray-50 transition-colors duration-150">
              <td class="px-6 py-4 font-mono text-xs text-gray-400">{item.id}</td>
              <td class="px-6 py-4 text-sm font-medium" style="color: #0b1f3a;">{item.nom}</td>
              <td class="px-6 py-4 text-sm text-gray-500">{item.email}</td>
              <td class="px-6 py-4 text-sm text-gray-400">
                {new Date(item.cree_le).toLocaleDateString("fr-FR", { day: "numeric", month: "short", year: "numeric" })}
              </td>
              <td class="px-6 py-4">
                <Badge variant={item.statut === "Actif" ? "vert" : "gris"}>{item.statut}</Badge>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal -->
  <div id="modal-generer" class="fixed inset-0 z-50 hidden items-center justify-center" style="background-color: rgba(0,0,0,0.5);">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md mx-4">
      <h2 class="text-lg font-semibold mb-6" style="color: #0b1f3a;">Générer un accès</h2>
      <form id="form-generer" class="flex flex-col gap-5">
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Nom complet</label>
          <input id="input-nom" type="text" placeholder="Prénom Nom"
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition" style="color: #0b1f3a;" />
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Adresse e-mail</label>
          <input id="input-email" type="email" placeholder="prenom.nom@exemple.fr"
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition" style="color: #0b1f3a;" />
        </div>

        <div id="result-genere" class="hidden rounded-xl p-4" style="background-color: rgba(212,167,98,0.06); border: 1px solid rgba(212,167,98,0.2);">
          <p class="text-xs font-medium uppercase tracking-widest mb-3" style="color: #d4a762;">Identifiants générés</p>
          <div class="flex flex-col gap-2">
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">E-mail</span>
              <span id="res-email" class="text-sm font-semibold" style="color: #0b1f3a;"></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-400">Mot de passe</span>
              <span id="res-password" class="font-mono text-sm font-semibold" style="color: #d4a762;"></span>
            </div>
          </div>
        </div>

        <div class="flex gap-3 justify-end pt-2">
          <button type="button" id="btn-annuler"
            class="px-5 py-2.5 rounded-full text-sm font-medium text-gray-500 hover:bg-gray-100 transition">Annuler</button>
          <button type="submit"
            class="px-5 py-2.5 rounded-full text-sm font-semibold text-white hover:opacity-90 transition" style="background-color: #0b1f3a;">
            Générer
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const modal = document.getElementById("modal-generer");
    document.getElementById("btn-generer").addEventListener("click", () => modal.classList.replace("hidden", "flex"));
    document.getElementById("btn-annuler").addEventListener("click", () => modal.classList.replace("flex", "hidden"));
    modal.addEventListener("click", (e) => { if (e.target === modal) modal.classList.replace("flex", "hidden"); });

    document.getElementById("form-generer").addEventListener("submit", (e) => {
      e.preventDefault();
      const email = document.getElementById("input-email").value;
      const chars = "ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789@#!";
      let pwd = "";
      for (let i = 0; i < 10; i++) pwd += chars[Math.floor(Math.random() * chars.length)];
      document.getElementById("res-email").textContent = email;
      document.getElementById("res-password").textContent = pwd;
      document.getElementById("result-genere").classList.remove("hidden");
    });
  </script>

</AdherentLayout>

