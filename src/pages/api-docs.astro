---
// Page publique — pas d'auth requise
---
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>API Documentation — JCBO-CONSEIL</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5/swagger-ui.css" />
    <style>
      body { margin: 0; background: #fafafa; }
      .topbar { background: #0b1f3a !important; }
      .topbar-wrapper img { content: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='120' height='30'><text y='22' font-family='sans-serif' font-weight='bold' font-size='16' fill='%23d4a762'>JCBO-CONSEIL</text></svg>"); }
      .info .title { color: #0b1f3a; }
      .btn.authorize { border-color: #d4a762 !important; color: #d4a762 !important; }
    </style>
  </head>
  <body>
    <div id="swagger-ui"></div>
    <script src="https://unpkg.com/swagger-ui-dist@5/swagger-ui-bundle.js"></script>
    <script>
      SwaggerUIBundle({
        url: "/openapi.yaml",
        dom_id: "#swagger-ui",
        presets: [SwaggerUIBundle.presets.apis, SwaggerUIBundle.SwaggerUIStandalonePreset],
        layout: "BaseLayout",
        deepLinking: true,
        tryItOutEnabled: true,
        persistAuthorization: true,
      });
    </script>
  </body>
</html>
