---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import { getCours, getProgressions, getAdherentByEmail } from "../../lib/store";

const profil = await getAdherentByEmail(Astro.locals.session?.email ?? "");
if (!profil) return Astro.redirect("/login");

const tousLesCours = (await getCours()).filter(c => c.statut === "Publié");
const progressions = await getProgressions(profil.email);

const mesFormations = tousLesCours
  .filter(c => profil.coursInscrits.includes(c.id))
  .map(c => {
    const prog = progressions.find(p => p.coursId === c.id);
    const modulesTermines = prog?.modulesTermines.length ?? 0;
    const total = c.modules.length;
    const pourcentage = total > 0 ? Math.round((modulesTermines / total) * 100) : 0;
    return { ...c, pourcentage, modulesTermines, totalModules: total };
  });
---

<AdherentMemberLayout titre="Mes cours">

  <div class="mb-6 flex items-center justify-between">
    <div>
      <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Mes cours</h2>
      <p class="text-sm text-gray-500 mt-1">Continuez votre progression.</p>
    </div>
    <a href="/adherent/marketplace" class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-semibold transition hover:opacity-90" style="background-color: #d4a762; color: #0b1f3a;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
      </svg>
      Marketplace
    </a>
  </div>

  {mesFormations.length > 0 ? (
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
      {mesFormations.map((c) => (
        <Card>
          <div class="flex flex-col h-full gap-4">
            <div>
              <div class="flex items-center gap-2 mb-3">
                <Badge variant={c.niveau === "Débutant" ? "or" : c.niveau === "Intermédiaire" ? "vert" : "gris"}>{c.niveau}</Badge>
                <span class="text-xs text-gray-400">{c.duree}</span>
                <span class="text-xs text-gray-400">·</span>
                <span class="text-xs text-gray-400">{c.totalModules} modules</span>
              </div>
              <h3 class="text-sm font-bold leading-snug" style="color: #0b1f3a;">{c.titre}</h3>
              <p class="text-xs text-gray-400 mt-1.5 line-clamp-2">{c.description}</p>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-xs text-gray-400">Progression</span>
                <span class="text-xs font-semibold" style={c.pourcentage === 100 ? "color: #16a34a;" : "color: #d4a762;"}>
                  {c.modulesTermines}/{c.totalModules} modules — {c.pourcentage}%
                </span>
              </div>
              <div class="w-full rounded-full h-1.5" style="background-color: #f1f3f5;">
                <div
                  class="h-1.5 rounded-full transition-all duration-500"
                  style={`width: ${c.pourcentage}%; background: ${c.pourcentage === 100 ? "#16a34a" : "linear-gradient(90deg, #d4a762, #0b1f3a)"};`}
                ></div>
              </div>
            </div>

            <a
              href={`/adherent/cours/${c.id}`}
              class="flex items-center justify-center gap-2 w-full py-2.5 rounded-xl text-sm font-semibold transition hover:opacity-90 mt-auto"
              style={c.pourcentage === 0
                ? "background-color: #0b1f3a; color: white;"
                : c.pourcentage === 100
                ? "background-color: rgba(22,163,74,0.1); color: #16a34a;"
                : "background-color: rgba(212,167,98,0.12); color: #0b1f3a;"}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                {c.pourcentage === 100
                  ? <polyline points="20 6 9 17 4 12"/>
                  : <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                }
              </svg>
              {c.pourcentage === 0 ? "Commencer" : c.pourcentage === 100 ? "Revoir le cours" : "Continuer"}
            </a>
          </div>
        </Card>
      ))}
    </div>
  ) : (
    <Card>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mb-4" style="background-color: rgba(212,167,98,0.1);">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
          </svg>
        </div>
        <p class="text-base font-semibold mb-1" style="color: #0b1f3a;">Aucun cours pour le moment</p>
        <p class="text-sm text-gray-400">Rendez-vous sur la marketplace pour choisir vos formations.</p>
        <a href="/adherent/marketplace" class="mt-5 px-5 py-2.5 rounded-xl text-sm font-semibold transition hover:opacity-90" style="background-color: #d4a762; color: #0b1f3a;">
          Voir la marketplace
        </a>
      </div>
    </Card>
  )}

</AdherentMemberLayout>
