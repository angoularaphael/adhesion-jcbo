---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import { getAdherentByEmail, getCours, getCoursTermines } from "../../lib/store";

const profil = getAdherentByEmail(Astro.locals.session?.email ?? "");
if (!profil) return Astro.redirect("/login");

const coursTerminesIds = getCoursTermines(profil.email);
const tousLesCours = getCours();
const certificats = coursTerminesIds.map(coursId => {
  const c = tousLesCours.find(x => x.id === coursId);
  if (!c) return null;
  return {
    coursId,
    titre: c.titre,
    numero: `JCBO-${coursId.replace("COURS-", "")}-${profil.numeroAdherent.split("-").pop()}`,
    dateDelivrance: new Date().toISOString().split("T")[0],
    adherent: `${profil.prenom} ${profil.nom}`,
  };
}).filter(Boolean) as { coursId: string; titre: string; numero: string; dateDelivrance: string; adherent: string }[];
---

<AdherentMemberLayout titre="Mes certificats">

  <div class="mb-8 flex items-center justify-between">
    <div>
      <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Mes certificats</h2>
      <p class="text-sm text-gray-500 mt-1">Les certificats sont générés à la completion de chaque cours (100% des modules + quiz réussis).</p>
    </div>
  </div>

  {certificats.length === 0 && (
    <Card>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mb-4" style="background-color: rgba(212,167,98,0.1);">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.5"><circle cx="12" cy="9" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 21l3-3 3 3V15a6 6 0 10-6 0v6z"/></svg>
        </div>
        <p class="text-base font-semibold mb-1" style="color: #0b1f3a;">Aucun certificat pour le moment</p>
        <p class="text-sm text-gray-400">Completez un cours en réussissant tous les quiz pour obtenir votre certificat.</p>
        <a href="/adherent/cours" class="mt-5 px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition hover:opacity-90" style="background-color: #d4a762; color: #0b1f3a;">
          Voir mes cours
        </a>
      </div>
    </Card>
  )}

  <div class="flex flex-col gap-6">
    {certificats.map(cert => (
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden" style="border: 1px solid #f1f3f5;" id={`cert-${cert.coursId}`}>
        <!-- Aperçu certificat -->
        <div class="relative overflow-hidden p-8 text-center" style="background: linear-gradient(135deg, #0b1f3a 0%, #162d4f 100%); min-height: 240px;">
          <div class="absolute top-0 right-0 w-64 h-64 rounded-full -translate-y-1/2 translate-x-1/4 opacity-[0.04]" style="background-color: #d4a762;"></div>
          <div class="absolute bottom-0 left-0 w-48 h-48 rounded-full translate-y-1/2 -translate-x-1/4 opacity-[0.05]" style="background-color: #d4a762;"></div>
          <div class="relative z-10">
            <p class="text-xs font-medium uppercase tracking-[0.25em] mb-4" style="color: rgba(212,167,98,0.6);">Certificat de Formation</p>
            <p class="text-sm mb-2" style="color: rgba(255,255,255,0.5);">Décerné à</p>
            <h3 class="text-2xl font-bold text-white mb-3" style="font-family: Georgia, serif;">{cert.adherent}</h3>
            <p class="text-sm mb-1" style="color: rgba(255,255,255,0.5);">pour avoir complété</p>
            <h4 class="text-lg font-semibold mb-4" style="color: #d4a762;">{cert.titre}</h4>
            <div class="flex items-center justify-center gap-8 text-xs" style="color: rgba(255,255,255,0.3);">
              <span>N° {cert.numero}</span>
              <span>·</span>
              <span>{new Date(cert.dateDelivrance).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</span>
            </div>
          </div>
        </div>
        <!-- Actions -->
        <div class="px-6 py-4 flex items-center justify-between" style="border-top: 1px solid #f1f3f5;">
          <div>
            <p class="text-sm font-semibold" style="color: #0b1f3a;">{cert.titre}</p>
            <p class="text-xs text-gray-400">Obtenu le {new Date(cert.dateDelivrance).toLocaleDateString("fr-FR")}</p>
          </div>
          <button
            class="btn-download-pdf px-4 py-2 rounded-xl text-sm font-semibold text-white flex items-center gap-2 transition hover:opacity-90"
            style="background-color: #0b1f3a;"
            data-cert={JSON.stringify(cert)}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v14a2 2 0 01-2 2z"/></svg>
            Télécharger PDF
          </button>
        </div>
      </div>
    ))}
  </div>

</AdherentMemberLayout>

<script is:inline>
(function() {
  document.querySelectorAll(".btn-download-pdf").forEach(btn => {
    btn.addEventListener("click", async function() {
      const cert = JSON.parse(this.dataset.cert);
      this.textContent = "Génération…";
      this.disabled = true;

      // Génération PDF avec jsPDF via CDN
      if (!window.jspdf) {
        await new Promise((resolve, reject) => {
          const s = document.createElement("script");
          s.src = "https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js";
          s.onload = resolve;
          s.onerror = reject;
          document.head.appendChild(s);
        });
      }

      const { jsPDF } = window.jspdf;
      const doc = new jsPDF({ orientation: "landscape", unit: "mm", format: "a4" });
      const W = 297, H = 210;

      // Fond bleu marine
      doc.setFillColor(11, 31, 58);
      doc.rect(0, 0, W, H, "F");

      // Bordure dorée
      doc.setDrawColor(212, 167, 98);
      doc.setLineWidth(1.5);
      doc.rect(10, 10, W - 20, H - 20);
      doc.setLineWidth(0.4);
      doc.rect(13, 13, W - 26, H - 26);

      // Titre certificat
      doc.setTextColor(212, 167, 98);
      doc.setFontSize(11);
      doc.setFont("helvetica", "normal");
      doc.text("CERTIFICAT DE FORMATION", W / 2, 38, { align: "center", charSpace: 3 });

      // Ligne décorative
      doc.setDrawColor(212, 167, 98);
      doc.setLineWidth(0.5);
      doc.line(W / 2 - 40, 43, W / 2 + 40, 43);

      // "Décerné à"
      doc.setTextColor(255, 255, 255);
      doc.setFontSize(10);
      doc.setFont("helvetica", "normal");
      doc.text("Décerné à", W / 2, 58, { align: "center" });

      // Nom adhérent
      doc.setFontSize(26);
      doc.setFont("times", "bold");
      doc.setTextColor(255, 255, 255);
      doc.text(cert.adherent, W / 2, 75, { align: "center" });

      // "pour avoir complété"
      doc.setFontSize(10);
      doc.setFont("helvetica", "normal");
      doc.setTextColor(180, 180, 180);
      doc.text("pour avoir complété avec succès la formation", W / 2, 90, { align: "center" });

      // Titre cours
      doc.setFontSize(16);
      doc.setFont("helvetica", "bold");
      doc.setTextColor(212, 167, 98);
      doc.text(cert.titre, W / 2, 103, { align: "center" });

      // Ligne séparatrice
      doc.setDrawColor(212, 167, 98);
      doc.setLineWidth(0.3);
      doc.line(W / 2 - 60, 112, W / 2 + 60, 112);

      // Infos bas
      doc.setFontSize(9);
      doc.setFont("helvetica", "normal");
      doc.setTextColor(140, 140, 140);
      const dateStr = new Date(cert.dateDelivrance).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
      doc.text(`N° ${cert.numero}`, W / 2 - 40, 125, { align: "center" });
      doc.text(`Délivré le ${dateStr}`, W / 2 + 40, 125, { align: "center" });

      // Signature JCBO
      doc.setFontSize(10);
      doc.setFont("times", "italic");
      doc.setTextColor(212, 167, 98);
      doc.text("JCBO Conseil", W / 2, 155, { align: "center" });
      doc.setFontSize(8);
      doc.setFont("helvetica", "normal");
      doc.setTextColor(100, 100, 100);
      doc.text("Cabinet de conseil aux entreprises", W / 2, 162, { align: "center" });

      doc.save(`Certificat_${cert.titre.replace(/[^a-zA-Z0-9]/g, "_")}_${cert.adherent.replace(/\s/g, "_")}.pdf`);

      this.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v14a2 2 0 01-2 2z"/></svg> Télécharger PDF`;
      this.disabled = false;
    });
  });
})();
</script>
