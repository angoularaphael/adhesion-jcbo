---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import { getAdherentByEmail, getCours, getCoursTermines } from "../../lib/store";

const profil = await getAdherentByEmail(Astro.locals.session?.email ?? "");
if (!profil) return Astro.redirect("/login");

const coursTerminesIds = await getCoursTermines(profil.email);
const tousLesCours = await getCours();
const certificats = coursTerminesIds.map((coursId) => {
  const c = tousLesCours.find((x) => x.id === coursId);
  if (!c) return null;
  const code = (c as { certificatCode?: string }).certificatCode || "ME";
  const competences = (c as { competences?: string[] }).competences ?? [];
  const adherentNumber = profil.numeroAdherent.split("-").pop() ?? "000000";
  return {
    coursId,
    titre: c.titre,
    numero: `JCBO-${code}-${adherentNumber}`,
    dateDelivrance: new Date().toISOString().split("T")[0],
    adherent: `${profil.prenom} ${profil.nom}`,
    competences,
    certificatIntro: (c as { certificatIntro?: string }).certificatIntro ?? "",
  };
}).filter(Boolean) as {
  coursId: string;
  titre: string;
  numero: string;
  dateDelivrance: string;
  adherent: string;
  competences: string[];
  certificatIntro: string;
}[];
---

<AdherentMemberLayout titre="Mes certificats">

  <div class="mb-8 flex items-center justify-between">
    <div>
      <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Mes certificats</h2>
      <p class="text-sm text-gray-500 mt-1">Délivrés à la complétion d'un cours (100 % des modules + quiz final validé à 80 %).</p>
    </div>
  </div>

  {certificats.length === 0 && (
    <Card>
      <div class="flex flex-col items-center justify-center py-16 text-center">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mb-4" style="background-color: rgba(212,167,98,0.1);">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.5"><circle cx="12" cy="9" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 21l3-3 3 3V15a6 6 0 10-6 0v6z"/></svg>
        </div>
        <p class="text-base font-semibold mb-1" style="color: #0b1f3a;">Aucun certificat pour le moment</p>
        <p class="text-sm text-gray-400">Complétez un cours en réussissant tous les quiz pour obtenir votre certificat.</p>
        <a href="/adherent/cours" class="mt-5 px-5 py-2.5 rounded-xl text-sm font-semibold transition hover:opacity-90" style="background-color: #d4a762; color: #0b1f3a;">
          Voir mes cours
        </a>
      </div>
    </Card>
  )}

  <div class="flex flex-col gap-6">
    {certificats.map((cert) => (
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden" style="border: 1px solid #f1f3f5;" id={`cert-${cert.coursId}`}>
        <div class="relative overflow-hidden p-8 text-center" style="background: linear-gradient(135deg, #0b1f3a 0%, #162d4f 100%); min-height: 200px;">
          <div class="absolute inset-0 opacity-[0.06]" style="background: repeating-linear-gradient(45deg, #d4a762 0, #d4a762 1px, transparent 0, transparent 50%); background-size: 8px 8px;"></div>
          <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, transparent, #d4a762, transparent);"></div>
          <div class="relative z-10">
            <p class="text-[10px] font-bold uppercase tracking-[0.3em] mb-3" style="color: #d4a762;">JCBO-CONSEIL</p>
            <p class="text-xs font-medium uppercase tracking-[0.2em] mb-4 text-white/60">Certificat de Formation</p>
            <p class="text-sm mb-1 text-white/50">Décerné à</p>
            <h3 class="text-2xl font-bold text-white mb-3" style="font-family: Georgia, serif;">{cert.adherent}</h3>
            <div class="inline-block px-4 py-1 rounded-full mb-3" style="background: rgba(212,167,98,0.15); border: 1px solid rgba(212,167,98,0.3);">
              <h4 class="text-sm font-semibold" style="color: #d4a762;">{cert.titre}</h4>
            </div>
            <div class="flex items-center justify-center gap-6 text-xs text-white/40">
              <span>N° {cert.numero}</span>
              <span>{new Date(cert.dateDelivrance).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</span>
            </div>
          </div>
        </div>
        <div class="px-6 py-4 flex items-center justify-between" style="border-top: 1px solid #f1f3f5;">
          <div>
            <p class="text-sm font-semibold" style="color: #0b1f3a;">{cert.titre}</p>
            <p class="text-xs text-gray-400">Obtenu le {new Date(cert.dateDelivrance).toLocaleDateString("fr-FR")}</p>
          </div>
          <button
            class="btn-download-pdf px-4 py-2 rounded-xl text-sm font-semibold text-white flex items-center gap-2 transition hover:opacity-90"
            style="background-color: #0b1f3a;"
            data-cert={JSON.stringify(cert)}
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v14a2 2 0 01-2 2z"/></svg>
            Télécharger PDF
          </button>
        </div>
      </div>
    ))}
  </div>

</AdherentMemberLayout>

<script is:inline>
(function() {
  const NAVY = [11, 31, 58];
  const GOLD = [212, 167, 98];
  const LIGHT_GOLD = [248, 246, 242];

  function loadImage(src, stripLightBackground) {
    return new Promise((resolve) => {
      const img = new Image();
      img.crossOrigin = "anonymous";
      img.onload = () => {
        const canvas = document.createElement("canvas");
        canvas.width = img.naturalWidth || img.width;
        canvas.height = img.naturalHeight || img.height;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(img, 0, 0);
        if (stripLightBackground) {
          const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
          const px = imageData.data;
          for (let i = 0; i < px.length; i += 4) {
            const r = px[i], g = px[i + 1], b = px[i + 2];
            const light = r > 210 && g > 210 && b > 210;
            const grey = r > 170 && g > 170 && b > 170 && Math.abs(r - g) < 25 && Math.abs(g - b) < 25;
            if (light || grey) px[i + 3] = 0;
          }
          ctx.putImageData(imageData, 0, 0);
        }
        resolve({ data: canvas.toDataURL("image/png"), width: canvas.width, height: canvas.height });
      };
      img.onerror = () => resolve(null);
      img.src = src;
    });
  }

  function wrap(doc, text, maxWidth) {
    return doc.splitTextToSize(text, maxWidth);
  }

  /** Cadre double doré + accents aux 4 coins, alignés sur le même rectangle. */
  function drawCertificateFrame(doc, x, y, w, h, gap) {
    doc.setDrawColor(...GOLD);

    // Bordure extérieure
    doc.setLineWidth(0.9);
    doc.rect(x, y, w, h);

    // Bordure intérieure
    doc.setLineWidth(0.25);
    doc.rect(x + gap, y + gap, w - 2 * gap, h - 2 * gap);

    // Accents de coin (L courts, même épaisseur que la bordure extérieure)
    const len = 10;
    doc.setLineWidth(0.9);
    const corners = [
      [x, y, 1, 1],
      [x + w, y, -1, 1],
      [x, y + h, 1, -1],
      [x + w, y + h, -1, -1],
    ];
    corners.forEach(([cx, cy, dx, dy]) => {
      doc.line(cx, cy, cx + dx * len, cy);
      doc.line(cx, cy, cx, cy + dy * len);
    });
  }

  document.querySelectorAll(".btn-download-pdf").forEach((btn) => {
    btn.addEventListener("click", async function () {
      const cert = JSON.parse(this.dataset.cert);
      const origHtml = this.innerHTML;
      this.textContent = "Génération…";
      this.disabled = true;

      try {
        if (!window.jspdf) {
          await new Promise((resolve, reject) => {
            const s = document.createElement("script");
            s.src = "https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js";
            s.onload = resolve;
            s.onerror = reject;
            document.head.appendChild(s);
          });
        }

        const [cachet, signature] = await Promise.all([
          loadImage("/images/cachet.png", true),
          loadImage("/images/signature-jcbo.png", false),
        ]);

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({ orientation: "landscape", unit: "mm", format: "a4" });
        const W = 297, H = 210;
        const M = 12;
        const GAP = 3;
        const frameX = M;
        const frameY = M;
        const frameW = W - 2 * M;
        const frameH = H - 2 * M;
        const innerX = frameX + GAP;
        const innerY = frameY + GAP;
        const innerW = frameW - 2 * GAP;
        const headerH = 28;

        // Fond blanc cassé
        doc.setFillColor(...LIGHT_GOLD);
        doc.rect(0, 0, W, H, "F");

        // Cadre doré (dessiné en premier, tout le contenu à l'intérieur)
        drawCertificateFrame(doc, frameX, frameY, frameW, frameH, GAP);

        // Bandeau header navy — contenu dans le cadre
        doc.setFillColor(...NAVY);
        doc.rect(innerX, innerY, innerW, headerH, "F");
        doc.setFillColor(...GOLD);
        doc.rect(innerX, innerY + headerH - 1.5, innerW, 1.5, "F");

        // Titre header
        doc.setTextColor(255, 255, 255);
        doc.setFont("times", "bold");
        doc.setFontSize(24);
        doc.text("CERTIFICAT DE FORMATION", W / 2, innerY + 12, { align: "center" });
        doc.setFont("helvetica", "normal");
        doc.setFontSize(8.5);
        doc.setTextColor(...GOLD);
        doc.text("JCBO-CONSEIL  ·  Cabinet de conseil aux entreprises", W / 2, innerY + 21, { align: "center", charSpace: 1.2 });

        let y = innerY + headerH + 14;

        // Corps principal
        doc.setFont("helvetica", "normal");
        doc.setFontSize(10.5);
        doc.setTextColor(55, 55, 55);
        doc.text("Le cabinet JCBO-CONSEIL certifie que :", W / 2, y, { align: "center" });
        y += 10;

        doc.setFont("times", "bolditalic");
        doc.setFontSize(22);
        doc.setTextColor(...NAVY);
        doc.text(cert.adherent, W / 2, y, { align: "center" });
        y += 3;
        doc.setDrawColor(...GOLD);
        doc.setLineWidth(0.4);
        doc.line(W / 2 - 55, y + 2, W / 2 + 55, y + 2);
        y += 10;

        doc.setFont("helvetica", "normal");
        doc.setFontSize(10);
        doc.setTextColor(65, 65, 65);
        doc.text("a suivi avec succès le programme de formation :", W / 2, y, { align: "center" });
        y += 7;

        doc.setFont("times", "bold");
        doc.setFontSize(15);
        doc.setTextColor(...GOLD);
        doc.text(`« ${cert.titre} »`, W / 2, y, { align: "center" });
        y += 8;

        doc.setFont("helvetica", "normal");
        doc.setFontSize(9.5);
        doc.setTextColor(75, 75, 75);
        const p2 = "et a validé l'ensemble des modules, exercices et évaluations associés,";
        const p3 = "conformément aux exigences pédagogiques du programme.";
        doc.text(p2, W / 2, y, { align: "center" }); y += 4.5;
        doc.text(p3, W / 2, y, { align: "center" }); y += 10;

        // Encadré compétences
        if (cert.competences && cert.competences.length > 0) {
          const boxX = innerX + 8, boxW = innerW - 16;
          const compLines = cert.competences.flatMap((c) => wrap(doc, "•  " + c, boxW - 16));
          const boxH = 8 + compLines.length * 4.5 + 4;

          doc.setFillColor(255, 255, 255);
          doc.setDrawColor(...GOLD);
          doc.setLineWidth(0.5);
          doc.roundedRect(boxX, y - 2, boxW, boxH, 2, 2, "FD");

          doc.setFont("helvetica", "bold");
          doc.setFontSize(9);
          doc.setTextColor(...NAVY);
          doc.text("Compétences développées :", boxX + 8, y + 4);

          doc.setFont("helvetica", "normal");
          doc.setFontSize(8.5);
          doc.setTextColor(70, 70, 70);
          let cy = y + 9;
          compLines.forEach((line) => {
            doc.text(line, boxX + 8, cy);
            cy += 4.5;
          });
          y += boxH + 6;
        }

        // Attestation
        doc.setFont("helvetica", "bold");
        doc.setFontSize(9);
        doc.setTextColor(...NAVY);
        doc.text("Ce certificat atteste de :", W / 2, y, { align: "center" });
        y += 5;
        doc.setFont("helvetica", "normal");
        doc.setFontSize(9);
        doc.setTextColor(70, 70, 70);
        const att = `la capacité du participant à mobiliser les fondamentaux du « ${cert.titre} » dans un contexte professionnel, entrepreneurial ou managérial.`;
        wrap(doc, att, innerW - 24).forEach((line) => {
          doc.text(line, W / 2, y, { align: "center" });
          y += 4.5;
        });

        if (cert.certificatIntro) {
          y += 3;
          doc.setFont("helvetica", "italic");
          doc.setFontSize(8);
          doc.setTextColor(120, 120, 120);
          wrap(doc, cert.certificatIntro, innerW - 24).forEach((line) => {
            doc.text(line, W / 2, y, { align: "center" });
            y += 4;
          });
        }

        // Pied : séparé du texte, signature/cachet sous la ligne (sans chevauchement)
        const sigW = 36;
        const sigH = signature ? (signature.height / signature.width) * sigW : 0;
        const cW = 28;
        const cH = cachet ? (cachet.height / cachet.width) * cW : 0;
        const sigBlockH = Math.max(sigH, cH) + 22;
        const legalY = frameY + frameH - 5;
        const maxFooterLine = legalY - sigBlockH - 4;
        const footerLineY = Math.min(Math.max(y + 10, innerY + headerH + 72), maxFooterLine);

        doc.setDrawColor(...GOLD);
        doc.setLineWidth(0.3);
        doc.line(innerX + 6, footerLineY, innerX + innerW - 6, footerLineY);

        const dateStr = new Date(cert.dateDelivrance).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
        const infoY = footerLineY + 7;

        doc.setFont("helvetica", "normal");
        doc.setFontSize(9);
        doc.setTextColor(60, 60, 60);
        doc.text(`Délivré le : ${dateStr}`, innerX + 10, infoY);
        doc.setFont("helvetica", "bold");
        doc.setTextColor(...NAVY);
        doc.text(`N° ${cert.numero}`, innerX + 10, infoY + 6);

        const sigX = innerX + innerW - 98;
        const imgY = footerLineY + 3;
        if (signature && signature.data) {
          doc.addImage(signature.data, "PNG", sigX, imgY, sigW, sigH);
        }
        if (cachet && cachet.data) {
          doc.addImage(cachet.data, "PNG", innerX + innerW - cW - 8, imgY, cW, cH);
        }

        const nameY = imgY + Math.max(sigH, cH) + 5;
        doc.setFont("helvetica", "bold");
        doc.setFontSize(8.5);
        doc.setTextColor(...NAVY);
        doc.text("Jean-Christophe BOYANG-TSANG", sigX + sigW / 2, nameY, { align: "center" });
        doc.setFont("helvetica", "normal");
        doc.setFontSize(7.5);
        doc.setTextColor(100, 100, 100);
        doc.text("Consultant en Business Development", sigX + sigW / 2, nameY + 4, { align: "center" });
        doc.text("Fondateur du cabinet JCBO-CONSEIL", sigX + sigW / 2, nameY + 8, { align: "center" });

        doc.setFontSize(6.5);
        doc.setTextColor(160, 160, 160);
        doc.text("Document officiel JCBO-CONSEIL — Toute falsification est passible de sanctions.", W / 2, legalY, { align: "center" });

        doc.save(`Certificat_${cert.titre.replace(/[^a-zA-Z0-9]/g, "_")}_${cert.adherent.replace(/\s/g, "_")}.pdf`);
      } catch (err) {
        alert(err.message || "Erreur lors de la génération du certificat.");
      } finally {
        this.innerHTML = origHtml;
        this.disabled = false;
      }
    });
  });
})();
</script>
