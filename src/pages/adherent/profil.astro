---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import { getAdherentByEmail } from "../../lib/store";

const profil = await getAdherentByEmail(Astro.locals.session?.email ?? "");
if (!profil) return Astro.redirect("/login");
---

<AdherentMemberLayout titre="Mon profil">

  <div class="mb-8">
    <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Mon profil</h2>
    <p class="text-sm text-gray-500 mt-1">Informations liées à votre adhésion JCBO Conseil.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Carte identité -->
    <Card class="flex flex-col items-center text-center gap-4">
      <div class="relative group">
        <div
          id="profil-avatar"
          class="w-24 h-24 rounded-full flex items-center justify-center text-2xl font-bold overflow-hidden"
          style={profil.photoUrl
            ? `background-image:url('${profil.photoUrl}');background-size:cover;background-position:center;`
            : "background: linear-gradient(135deg, #0b1f3a 0%, #162d4f 100%); color: #d4a762;"}
        >
          {!profil.photoUrl && <span>{profil.prenom[0]}{profil.nom[0]}</span>}
        </div>
        <button
          id="btn-edit-photo"
          type="button"
          class="absolute bottom-0 right-0 w-8 h-8 rounded-full flex items-center justify-center shadow-md border-2 border-white transition hover:scale-110"
          style="background-color: #d4a762; color: white;"
          aria-label="Modifier la photo de profil"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>
          </svg>
        </button>
        <input id="input-photo" type="file" accept="image/jpeg,image/png,image/webp" class="hidden" />
      </div>
      <p id="photo-status" class="hidden text-xs text-gray-400"></p>
      <div>
        <p class="font-semibold text-lg" style="color: #0b1f3a;">{profil.prenom} {profil.nom}</p>
        <p class="text-xs text-gray-400 mt-0.5">{profil.entreprise}</p>
      </div>
      <Badge variant="vert">{profil.statut}</Badge>
      <div class="w-full pt-3" style="border-top: 1px solid #f1f3f5;">
        <p class="text-xs text-gray-400 mb-1">N° adhérent</p>
        <p class="text-sm font-mono font-semibold" style="color: #d4a762;">{profil.numeroAdherent}</p>
      </div>
      <div class="w-full">
        <p class="text-xs text-gray-400 mb-1">Membre depuis</p>
        <p class="text-sm font-medium" style="color: #0b1f3a;">
          {new Date(profil.dateAdhesion).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
        </p>
      </div>
    </Card>

    <!-- Informations détaillées -->
    <div class="lg:col-span-2 flex flex-col gap-6">

      <!-- Infos non-modifiables -->
      <Card>
        <h3 class="text-sm font-semibold mb-5" style="color: #0b1f3a;">Informations du compte</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          {[
            { label: "Prénom", valeur: profil.prenom },
            { label: "Nom", valeur: profil.nom },
            { label: "E-mail", valeur: profil.email },
          ].map((c) => (
            <div>
              <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">{c.label}</p>
              <p class="text-sm font-medium" style="color: #0b1f3a;">{c.valeur}</p>
            </div>
          ))}
        </div>
      </Card>

      <!-- Infos modifiables -->
      <Card>
        <div class="flex items-center justify-between mb-5">
          <h3 class="text-sm font-semibold" style="color: #0b1f3a;">Informations professionnelles</h3>
          <button id="btn-edit-profil"
            class="px-3 py-1.5 rounded-full text-xs font-medium transition hover:opacity-80"
            style="background-color: rgba(212,167,98,0.1); color: #d4a762;">
            Modifier
          </button>
        </div>

        <!-- Vue lecture -->
        <div id="profil-view" class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Téléphone</p>
            <p id="view-telephone" class="text-sm font-medium" style="color: #0b1f3a;">{profil.telephone}</p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Entreprise</p>
            <p id="view-entreprise" class="text-sm font-medium" style="color: #0b1f3a;">{profil.entreprise}</p>
          </div>
          <div class="sm:col-span-2">
            <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">Secteur d'activité</p>
            <p id="view-secteur" class="text-sm font-medium" style="color: #0b1f3a;">{profil.secteur}</p>
          </div>
        </div>

        <!-- Formulaire d'édition -->
        <form id="form-profil" class="hidden flex-col gap-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Téléphone</label>
              <input id="input-telephone" type="tel" value={profil.telephone}
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762]" style="color: #0b1f3a;" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Entreprise</label>
              <input id="input-entreprise" type="text" value={profil.entreprise}
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762]" style="color: #0b1f3a;" />
            </div>
            <div class="flex flex-col gap-1.5 sm:col-span-2">
              <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Secteur d'activité</label>
              <input id="input-secteur" type="text" value={profil.secteur}
                class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762]" style="color: #0b1f3a;" />
            </div>
          </div>
          <p id="profil-error" class="hidden text-xs text-red-400"></p>
          <p id="profil-success" class="hidden text-xs font-medium" style="color: #d4a762;">Profil mis à jour avec succès.</p>
          <div class="flex gap-3">
            <button type="button" id="btn-annuler-profil"
              class="px-5 py-2.5 rounded-full text-sm font-medium text-gray-500 hover:bg-gray-100 transition">Annuler</button>
            <button type="submit" id="btn-submit-profil"
              class="px-5 py-2.5 rounded-full text-sm font-semibold text-white hover:opacity-90 transition disabled:opacity-60" style="background-color: #0b1f3a;">
              Enregistrer
            </button>
          </div>
        </form>
      </Card>

      <!-- Changer le mot de passe -->
      <Card>
        <h3 class="text-sm font-semibold mb-5" style="color: #0b1f3a;">Changer le mot de passe</h3>
        <form id="form-mdp" class="flex flex-col gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Mot de passe actuel</label>
            <input id="mdp-ancien" type="password" placeholder="••••••••"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762]" style="color: #0b1f3a;" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Nouveau mot de passe</label>
            <input id="mdp-nouveau" type="password" placeholder="Min. 8 caractères, 1 majuscule, 1 chiffre"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762]" style="color: #0b1f3a;" />
          </div>
          <p id="mdp-error" class="hidden text-xs text-red-400"></p>
          <p id="mdp-success" class="hidden text-xs font-medium" style="color: #16a34a;">Mot de passe mis à jour. Reconnectez-vous avec le nouveau mot de passe.</p>
          <button type="submit" id="btn-mdp"
            class="self-start px-6 py-2.5 rounded-full text-sm font-semibold text-white transition hover:opacity-90 disabled:opacity-60"
            style="background-color: #0b1f3a;">
            Mettre à jour
          </button>
        </form>
      </Card>

    </div>
  </div>

  <script>
    import { uploadFile } from "../../scripts/ui-loading";

    const profilView = document.getElementById("profil-view") as HTMLElement;
    const formProfil = document.getElementById("form-profil") as HTMLFormElement;

    // — Photo de profil —
    const btnEditPhoto = document.getElementById("btn-edit-photo") as HTMLButtonElement | null;
    const inputPhoto = document.getElementById("input-photo") as HTMLInputElement | null;
    const photoStatus = document.getElementById("photo-status") as HTMLParagraphElement | null;
    const avatarEl = document.getElementById("profil-avatar") as HTMLElement | null;

    if (btnEditPhoto && inputPhoto) {
      btnEditPhoto.addEventListener("click", () => inputPhoto.click());
      inputPhoto.addEventListener("change", async () => {
        const file = inputPhoto.files?.[0];
        if (!file || !photoStatus || !avatarEl) return;
        if (file.size > 10 * 1024 * 1024) {
          photoStatus.textContent = "Image trop volumineuse (max 10 Mo).";
          photoStatus.style.color = "#ef4444";
          photoStatus.classList.remove("hidden");
          return;
        }
        photoStatus.textContent = "Envoi vers Cloudinary…";
        photoStatus.style.color = "#9ca3af";
        photoStatus.classList.remove("hidden");

        try {
          const { url } = await uploadFile(file, "profils", "adherent");
          const save = await fetch("/api/profil/photo", {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ photoUrl: url }),
          });
          const saveData = await save.json();
          if (!save.ok) {
            photoStatus.textContent = saveData.error || "Erreur d'enregistrement.";
            photoStatus.style.color = "#ef4444";
            return;
          }

          avatarEl.style.backgroundImage = `url('${url}')`;
          avatarEl.style.backgroundSize = "cover";
          avatarEl.style.backgroundPosition = "center";
          avatarEl.innerHTML = "";
          photoStatus.textContent = "Photo de profil mise à jour.";
          photoStatus.style.color = "#16a34a";
          setTimeout(() => photoStatus.classList.add("hidden"), 2500);
        } catch (e) {
          photoStatus.textContent = e instanceof Error ? e.message : "Erreur d'envoi.";
          photoStatus.style.color = "#ef4444";
        }
      });
    }

    document.getElementById("btn-edit-profil")!.addEventListener("click", () => {
      profilView.classList.add("hidden");
      formProfil.classList.remove("hidden");
      formProfil.classList.add("flex");
      document.getElementById("profil-error")!.classList.add("hidden");
      document.getElementById("profil-success")!.classList.add("hidden");
    });

    document.getElementById("btn-annuler-profil")!.addEventListener("click", () => {
      formProfil.classList.add("hidden");
      formProfil.classList.remove("flex");
      profilView.classList.remove("hidden");
    });

    formProfil.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("btn-submit-profil") as HTMLButtonElement;
      const errEl = document.getElementById("profil-error") as HTMLParagraphElement;
      const okEl = document.getElementById("profil-success") as HTMLParagraphElement;
      btn.disabled = true;
      btn.textContent = "Enregistrement…";
      errEl.classList.add("hidden");
      okEl.classList.add("hidden");

      const telephone = (document.getElementById("input-telephone") as HTMLInputElement).value;
      const entreprise = (document.getElementById("input-entreprise") as HTMLInputElement).value;
      const secteur = (document.getElementById("input-secteur") as HTMLInputElement).value;

      const res = await fetch("/api/profil", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ telephone, entreprise, secteur }),
      });
      const data = await res.json();

      if (res.ok) {
        document.getElementById("view-telephone")!.textContent = data.telephone;
        document.getElementById("view-entreprise")!.textContent = data.entreprise;
        document.getElementById("view-secteur")!.textContent = data.secteur;
        okEl.classList.remove("hidden");
        setTimeout(() => {
          formProfil.classList.add("hidden");
          formProfil.classList.remove("flex");
          profilView.classList.remove("hidden");
        }, 1200);
      } else {
        errEl.textContent = data.error || "Erreur lors de la mise à jour.";
        errEl.classList.remove("hidden");
      }
      btn.disabled = false;
      btn.textContent = "Enregistrer";
    });

    document.getElementById("form-mdp")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("btn-mdp") as HTMLButtonElement;
      const errEl = document.getElementById("mdp-error") as HTMLParagraphElement;
      const okEl = document.getElementById("mdp-success") as HTMLParagraphElement;
      errEl.classList.add("hidden");
      okEl.classList.add("hidden");
      btn.disabled = true;
      btn.textContent = "Mise à jour…";

      const ancienMotDePasse = (document.getElementById("mdp-ancien") as HTMLInputElement).value;
      const nouveauMotDePasse = (document.getElementById("mdp-nouveau") as HTMLInputElement).value;

      const res = await fetch("/api/auth/password", {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ ancienMotDePasse, nouveauMotDePasse }),
      });
      const data = await res.json();

      if (res.ok) {
        okEl.classList.remove("hidden");
        (document.getElementById("mdp-ancien") as HTMLInputElement).value = "";
        (document.getElementById("mdp-nouveau") as HTMLInputElement).value = "";
      } else {
        errEl.textContent = data.error || "Erreur.";
        errEl.classList.remove("hidden");
      }
      btn.disabled = false;
      btn.textContent = "Mettre à jour";
    });
  </script>

</AdherentMemberLayout>
