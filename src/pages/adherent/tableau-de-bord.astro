---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import { mockAdherent, mockAdhesion, mockActualites, mockRessources } from "../../data/mock";

const dateFinFormatee = new Date(mockAdhesion.dateFin).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
const joursRestants = Math.ceil((new Date(mockAdhesion.dateFin).getTime() - Date.now()) / 86400000);
const actualitesRecentes = mockActualites.filter(a => a.statut === "Publié").slice(0, 2);
---

<AdherentMemberLayout titre="Tableau de bord">

  <!-- Bannière de bienvenue -->
  <div class="rounded-2xl p-6 lg:p-8 mb-8 relative overflow-hidden" style="background: linear-gradient(135deg, #0b1f3a 0%, #162d4f 100%);">
    <div class="absolute top-0 right-0 w-64 h-64 rounded-full -translate-y-1/2 translate-x-1/4 opacity-[0.04]" style="background-color: #d4a762;"></div>
    <div class="absolute bottom-0 left-1/3 w-48 h-48 rounded-full translate-y-1/2 opacity-[0.03]" style="background-color: #d4a762;"></div>
    <div class="relative z-10">
      <p class="text-xs font-medium uppercase tracking-widest mb-2" style="color: rgba(212,167,98,0.7);">Bienvenue</p>
      <h2 class="text-2xl lg:text-3xl font-bold text-white mb-1">{mockAdherent.prenom} {mockAdherent.nom}</h2>
      <p class="text-sm" style="color: rgba(255,255,255,0.45);">{mockAdherent.entreprise} — {mockAdherent.secteur}</p>
    </div>
  </div>

  <!-- Statut adhésion -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <Card class="flex items-center gap-4">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(212,167,98,0.1);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.8">
          <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-0.5">Statut adhésion</p>
        <Badge variant="vert">Active</Badge>
      </div>
    </Card>

    <Card class="flex items-center gap-4">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(212,167,98,0.1);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.8">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6" stroke-linecap="round"/><line x1="8" y1="2" x2="8" y2="6" stroke-linecap="round"/><line x1="3" y1="10" x2="21" y2="10" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-0.5">Renouvellement</p>
        <p class="text-sm font-semibold" style="color: #0b1f3a;">{dateFinFormatee}</p>
      </div>
    </Card>

    <Card class="flex items-center gap-4">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0" style="background-color: rgba(212,167,98,0.1);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.8">
          <circle cx="12" cy="9" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 21l3-3 3 3V15a6 6 0 10-6 0v6z"/>
        </svg>
      </div>
      <div>
        <p class="text-xs text-gray-400 mb-0.5">Programme</p>
        <p class="text-sm font-semibold" style="color: #0b1f3a;">MINDSET ENTREPRENEURIAL™</p>
      </div>
    </Card>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Accès rapides -->
    <div class="flex flex-col gap-4">
      <h3 class="text-sm font-semibold" style="color: #0b1f3a;">Accès rapides</h3>

      <a href="/adherent/certificat" class="block">
        <Card class="flex items-center gap-4 hover:shadow-md transition-shadow cursor-pointer group">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform" style="background-color: rgba(212,167,98,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.8">
              <circle cx="12" cy="9" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 21l3-3 3 3V15a6 6 0 10-6 0v6z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold" style="color: #0b1f3a;">Mon certificat</p>
            <p class="text-xs text-gray-400">MINDSET ENTREPRENEURIAL™</p>
          </div>
        </Card>
      </a>

      <a href="/adherent/ressources" class="block">
        <Card class="flex items-center gap-4 hover:shadow-md transition-shadow cursor-pointer group">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform" style="background-color: rgba(11,31,58,0.06);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#0b1f3a" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold" style="color: #0b1f3a;">Ressources</p>
            <p class="text-xs text-gray-400">{mockRessources.length} documents disponibles</p>
          </div>
        </Card>
      </a>

      <a href="/adherent/contact" class="block">
        <Card class="flex items-center gap-4 hover:shadow-md transition-shadow cursor-pointer group">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform" style="background-color: rgba(11,31,58,0.06);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#0b1f3a" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4-4 7-9 7a9.9 9.9 0 01-4-.8L3 20l1.8-4A7 7 0 013 12c0-4 4-7 9-7s9 3 9 7z"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold" style="color: #0b1f3a;">Contacter JCBO</p>
            <p class="text-xs text-gray-400">Envoyer une demande</p>
          </div>
        </Card>
      </a>
    </div>

    <!-- Actualités JCBO -->
    <div class="lg:col-span-2">
      <h3 class="text-sm font-semibold mb-4" style="color: #0b1f3a;">Actualités JCBO Conseil</h3>
      <div class="flex flex-col gap-4">
        {actualitesRecentes.map((a) => (
          <Card>
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold mb-1" style="color: #0b1f3a;">{a.titre}</p>
                <p class="text-xs text-gray-500 leading-relaxed">{a.contenu}</p>
              </div>
              <p class="text-xs text-gray-300 flex-shrink-0">
                {new Date(a.date).toLocaleDateString("fr-FR", { day: "numeric", month: "short" })}
              </p>
            </div>
          </Card>
        ))}
      </div>
    </div>

  </div>

</AdherentMemberLayout>
