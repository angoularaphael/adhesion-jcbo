---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import Badge from "../../components/ui/Badge.astro";
import Stripe from "stripe";
import {
  getAdherentByEmail, setAbonnement, enregistrerPaiement,
  addNotification, getPaiementParSession,
} from "../../lib/store";

let profil = await getAdherentByEmail(Astro.locals.session?.email ?? "");
if (!profil) return Astro.redirect("/login");

const sessionId = Astro.url.searchParams.get("session_id") ?? "";
let abonnementActive = false;
let planActive = "";

// Fallback : traitement si webhook n'a pas encore tourné
if (sessionId) {
  const existingPaiement = await getPaiementParSession(sessionId);
  if (existingPaiement && existingPaiement.coursTitre.startsWith("Abonnement ")) {
    abonnementActive = true;
    planActive = existingPaiement.coursTitre.replace("Abonnement ", "");
  } else if (!existingPaiement) {
    const stripeKey = import.meta.env.STRIPE_SECRET_KEY;
    if (stripeKey && !stripeKey.includes("REMPLACER")) {
      try {
        const stripe = new Stripe(stripeKey);
        const session = await stripe.checkout.sessions.retrieve(sessionId);
        if (
          session.metadata?.type === "abonnement" &&
          (session.payment_status === "paid" || session.status === "complete")
        ) {
          const { adherentEmail, planNom, montant } = session.metadata;
          const email = (adherentEmail ?? profil.email).toLowerCase();
          const adherentTarget = await getAdherentByEmail(email);
          if (adherentTarget) {
            await setAbonnement(adherentTarget.id, planNom);
            await enregistrerPaiement({
              adherentEmail: email,
              coursId: "",
              coursTitre: `Abonnement ${planNom}`,
              montant: Number(montant ?? 0),
              stripeSessionId: sessionId,
            });
            await addNotification({
              adherentEmail: email,
              type: "abonnement",
              titre: "Abonnement activé",
              message: `Votre abonnement Plan ${planNom} (${montant} €/mois) est maintenant actif. Profitez de tous vos avantages JCBO-CONSEIL.`,
            });
            profil = await getAdherentByEmail(email) ?? profil;
          }
          abonnementActive = true;
          planActive = planNom;
        }
      } catch { /* session invalide ou clés manquantes */ }
    }
  }
}

const abonnement = profil.abonnement;

const plans = [
  {
    nom: "Découverte",
    prix: "Gratuit",
    periode: "",
    description: "Accès limité pour découvrir la plateforme.",
    fonctionnalites: ["Accès aux actualités", "1 ressource disponible", "Support par e-mail"],
    couleur: "#6b7280",
    bg: "rgba(107,114,128,0.05)",
  },
  {
    nom: "Standard",
    prix: "49 €",
    periode: "/ mois",
    description: "Idéal pour les entrepreneurs actifs qui veulent progresser.",
    fonctionnalites: ["Tous les cours publiés", "Ressources illimitées", "Messagerie prioritaire", "Certificats de formation"],
    couleur: "#d4a762",
    bg: "rgba(212,167,98,0.06)",
    recommande: true,
  },
  {
    nom: "Premium",
    prix: "99 €",
    periode: "/ mois",
    description: "Accompagnement personnalisé et accès exclusif.",
    fonctionnalites: ["Tout le Standard", "Sessions coaching individuel", "Accès anticipé aux nouveaux cours", "Réseau exclusif d'adhérents"],
    couleur: "#0b1f3a",
    bg: "rgba(11,31,58,0.04)",
  },
];
---

<AdherentMemberLayout titre="Mon abonnement">

  <div class="mb-8">
    <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Mon abonnement</h2>
    <p class="text-sm text-gray-500 mt-1">Choisissez le plan adapté à votre ambition.</p>
  </div>

  <!-- Bandeau succès après paiement -->
  {abonnementActive && (
    <div class="flex items-center gap-4 p-5 rounded-2xl mb-8" style="background: linear-gradient(135deg, rgba(22,163,74,0.08) 0%, rgba(22,163,74,0.04) 100%); border: 1px solid rgba(22,163,74,0.2);">
      <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0" style="background-color: rgba(22,163,74,0.12);">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#16a34a" stroke-width="2.5">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <div>
        <p class="text-sm font-bold" style="color: #15803d;">Abonnement activé avec succès</p>
        <p class="text-xs text-gray-500 mt-0.5">Votre plan <strong>{planActive}</strong> est maintenant actif. Accédez à tous vos avantages.</p>
      </div>
    </div>
  )}

  <!-- Abonnement actuel -->
  {abonnement && abonnement.statut === "actif" && (
    <div class="rounded-2xl p-5 mb-8 flex items-center justify-between gap-4" style="background: linear-gradient(135deg, #0b1f3a 0%, #162d4f 100%);">
      <div>
        <p class="text-xs font-medium uppercase tracking-widest mb-1" style="color: rgba(212,167,98,0.7);">Abonnement actuel</p>
        <h3 class="text-xl font-bold text-white">{abonnement.plan}</h3>
        <p class="text-xs mt-1" style="color: rgba(255,255,255,0.4);">Actif depuis le {new Date(abonnement.dateDebut).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}</p>
      </div>
      <div class="flex flex-col items-end gap-3">
        <Badge variant="vert">Actif</Badge>
        <button id="btn-cancel" class="text-xs underline" style="color: rgba(255,255,255,0.3);">Résilier</button>
      </div>
    </div>
  )}

  <!-- Plans -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
    {plans.map(plan => {
      const estActuel = abonnement?.statut === "actif" && abonnement?.plan === plan.nom;
      return (
        <div
          class="rounded-2xl p-6 flex flex-col relative"
          style={`background-color: ${plan.bg}; border: 2px solid ${estActuel ? plan.couleur : (plan as { recommande?: boolean }).recommande ? "rgba(212,167,98,0.3)" : "#f1f3f5;"};`}
        >
          {(plan as { recommande?: boolean }).recommande && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 text-xs font-bold px-3 py-1 rounded-full text-white" style="background-color: #d4a762;">
              Recommandé
            </span>
          )}
          <div class="mb-4">
            <p class="text-xs font-semibold uppercase tracking-wide mb-1" style={`color: ${plan.couleur};`}>{plan.nom}</p>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold" style="color: #0b1f3a;">{plan.prix}</span>
              {plan.periode && <span class="text-sm text-gray-400">{plan.periode}</span>}
            </div>
            <p class="text-xs text-gray-500 mt-2">{plan.description}</p>
          </div>
          <ul class="flex flex-col gap-2 flex-1 mb-6">
            {plan.fonctionnalites.map(f => (
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#16a34a" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                {f}
              </li>
            ))}
          </ul>
          {estActuel ? (
            <div class="w-full py-2.5 rounded-xl text-sm font-semibold text-center" style={`background-color: ${plan.couleur}22; color: ${plan.couleur};`}>
              Plan actuel
            </div>
          ) : (
            <div class="flex flex-col gap-2">
              <button
                class="btn-souscrire w-full py-2.5 rounded-xl text-sm font-semibold transition hover:opacity-90"
                style={`background-color: ${plan.couleur}; color: ${plan.couleur === "#0b1f3a" ? "white" : plan.couleur === "#d4a762" ? "#0b1f3a" : "white"};`}
                data-plan={plan.nom}
                data-methode="stripe"
              >
                {plan.nom === "Découverte" ? "Choisir ce plan" : "Carte bancaire"}
              </button>
              {plan.nom !== "Découverte" && (
                <button
                  class="btn-souscrire w-full py-2.5 rounded-xl text-sm font-semibold border transition hover:opacity-90"
                  style="border-color:#0b1f3a;color:#0b1f3a;"
                  data-plan={plan.nom}
                  data-methode="fapshi"
                >
                  OM / MoMo (Fapshi)
                </button>
              )}
            </div>
          )}
        </div>
      );
    })}
  </div>

  <p class="text-xs text-center text-gray-400">Paiement par carte (Stripe) ou OM/MoMo (Fapshi) · Résiliation possible à tout moment.</p>

  <p id="sub-error" class="text-red-500 text-sm text-center mt-4 hidden"></p>

</AdherentMemberLayout>

<script is:inline>
(function() {
  document.querySelectorAll(".btn-souscrire").forEach(function(btn) {
    btn.addEventListener("click", async function() {
      var plan = this.dataset.plan;
      var err = document.getElementById("sub-error");
      err.classList.add("hidden");
      this.disabled = true;

      // Plan gratuit : activation directe
      if (plan === "Découverte") {
        this.textContent = "Activation…";
        try {
          var res = await fetch("/api/abonnement", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ plan: plan }),
          });
          var data = await res.json();
          if (!res.ok) {
            err.textContent = data.error || "Erreur";
            err.classList.remove("hidden");
            this.disabled = false;
            this.textContent = "Choisir ce plan";
            return;
          }
          window.location.reload();
        } catch {
          err.textContent = "Erreur réseau";
          err.classList.remove("hidden");
          this.disabled = false;
          this.textContent = "Choisir ce plan";
        }
        return;
      }

      var methode = (this.dataset.methode || "stripe");
      this.textContent = "Redirection vers le paiement…";
      try {
        var endpoint = methode === "fapshi" ? "/api/fapshi/checkout" : "/api/stripe/checkout";
        var body = { planNom: plan };
        if (methode === "fapshi") {
          var phone = prompt("Numéro Mobile Money (ex: 670000000) — laissez vide pour lien de paiement :");
          if (phone) body.phone = phone;
        }
        var res2 = await fetch(endpoint, {
          method: "POST", headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        var data2 = await res2.json();
        if (!res2.ok) {
          err.textContent = data2.error || "Impossible d'initialiser le paiement";
          err.classList.remove("hidden");
          this.disabled = false;
          this.textContent = methode === "fapshi" ? "OM / MoMo" : "Carte bancaire";
          return;
        }
        if (data2.url) window.location.href = data2.url;
        else { alert("Demande de paiement envoyée sur votre téléphone."); window.location.reload(); }
      } catch {
        err.textContent = "Erreur réseau";
        err.classList.remove("hidden");
        this.disabled = false;
        this.textContent = "S'abonner";
      }
    });
  });

  var cancelBtn = document.getElementById("btn-cancel");
  if (cancelBtn) {
    cancelBtn.addEventListener("click", async function() {
      if (!confirm("Confirmer la résiliation de votre abonnement ?")) return;
      var res = await fetch("/api/abonnement", { method: "DELETE" });
      if (res.ok) window.location.href = "/adherent/abonnement";
    });
  }
})();
</script>
