---
import AdherentMemberLayout from "../../../layouts/AdherentMemberLayout.astro";
import Badge from "../../../components/ui/Badge.astro";
import { getCours, getProgressions, getAdherentByEmail } from "../../../lib/store";
import { getQuizQuestions } from "../../../lib/store-admin";

const { id } = Astro.params;
const cours = (await getCours()).find(c => c.id === id && c.statut === "Publié");

if (!cours) return Astro.redirect("/adherent/cours");

const profil = await getAdherentByEmail(Astro.locals.session?.email ?? "");
if (!profil) return Astro.redirect("/login");
const progressions = await getProgressions(profil.email);
const prog = progressions.find(p => p.coursId === cours.id);
const modulesTermines: string[] = prog?.modulesTermines ?? [];
const quizResultats = prog?.quizResultats ?? [];
const pourcentage = cours.modules.length > 0
  ? Math.round((modulesTermines.length / cours.modules.length) * 100)
  : 0;
const coursTermine = pourcentage === 100 && quizResultats.filter(q => q.passe).length >= cours.modules.length;

const contenuParModule: Record<string, string> = {
  M01: `Le mindset entrepreneurial est avant tout une façon d'appréhender la réalité avec exigence et discernement. Il ne s'agit pas d'optimisme naïf, mais d'une capacité à maintenir une vision claire tout en naviguant dans l'incertitude.\n\nUn entrepreneur performant développe trois attitudes fondamentales : la responsabilité totale (ne jamais se poser en victime des circonstances), la pensée en termes de solutions plutôt que de problèmes, et la discipline de l'action quotidienne même en l'absence de motivation.\n\nCette première leçon pose les bases de votre transformation. Prenez le temps de noter dans votre journal les domaines où vous avez tendance à subir plutôt qu'à agir. C'est le premier pas vers un mindset de haute performance.`,
  M02: `La posture professionnelle se construit dans les détails : comment vous vous présentez, comment vous communiquez, comment vous gérez votre temps et votre énergie. Elle précède et conditionne toute relation commerciale ou partenariale.\n\nTrois piliers à développer immédiatement : (1) La cohérence entre votre discours et vos actes — vos clients et partenaires observent tout. (2) La maîtrise émotionnelle — réagir avec mesure dans toutes les situations. (3) L'image professionnelle numérique — votre présence en ligne doit refléter le niveau d'excellence que vous incarnez.\n\nExercice pratique : Faites auditer votre profil LinkedIn par un pair ou un mentor. Identifiez 3 points d'amélioration concrets et appliquez-les avant la prochaine session.`,
  M03: `Structurer son activité, c'est passer d'une logique de réaction permanente à une logique de pilotage. Sans structure, vous êtes condamné à travailler dans votre activité plutôt que sur votre activité.\n\nLes trois outils essentiels de structuration : (1) Un modèle économique formalisé — qui paie quoi, pourquoi et comment. (2) Un plan stratégique à 90 jours — des objectifs précis, mesurables et réalistes. (3) Un tableau de bord de pilotage — 5 à 7 indicateurs clés que vous suivez chaque semaine.\n\nLivrable de cette leçon : rédigez votre modèle économique en une page. Identifiez vos 3 offres principales, leur prix, leur valeur perçue et leur canal de distribution.`,
  M04: `La prise de décision est une compétence qui se développe. Les décisions lentes ou incomplètes coûtent autant que les mauvaises décisions. Un entrepreneur performant décide vite, agit, mesure, ajuste.\n\nLe cadre OODA (Observe, Orient, Decide, Act) est particulièrement adapté à l'environnement entrepreneurial. Il permet de sortir d'une posture d'analyse paralysante pour entrer dans une dynamique d'action apprenante.\n\nPrincipe clé du pilotage : distinguez les indicateurs avancés (qui prédisent vos résultats futurs) des indicateurs retardés (qui constatent vos résultats passés). Pilotez sur les indicateurs avancés.`,
  M05: `Le leadership n'est pas un titre, c'est un comportement quotidien. Il se manifeste dans la façon dont vous tenez vos engagements, dont vous gérez les tensions, dont vous créez les conditions pour que les autres progressent.\n\nLa discipline opérationnelle, c'est la capacité à exécuter vos priorités même quand ce n'est pas confortable. Elle repose sur trois pratiques : la planification hebdomadaire (le dimanche soir ou le lundi matin), les rituels quotidiens d'exécution, et la revue de performance régulière.\n\nPoint d'attention : le perfectionnisme est l'ennemi de l'exécution. Apprenez à distinguer ce qui mérite l'excellence de ce qui mérite juste d'être fait.`,
  M06: `La vision business est la capacité à voir votre activité à 3-5 ans et à prendre des décisions aujourd'hui qui vous rapprochent de cette vision. Sans vision, vous optimisez le court terme au détriment du long terme.\n\nLa performance se mesure sur trois niveaux : financier (rentabilité, trésorerie, valeur de l'entreprise), opérationnel (qualité, efficacité, scalabilité) et stratégique (positionnement, avantage concurrentiel, croissance).\n\nExercice final : rédigez votre "Big Picture" — une description en 300 mots de votre activité dans 3 ans.`,
  M07: `La communication d'impact est la capacité à transmettre un message clair, mémorable et mobilisateur. Elle se distingue de la simple éloquence par son orientation vers le résultat.\n\nLa crédibilité professionnelle, quant à elle, se construit sur la durée à travers trois piliers : l'expertise démontrable, la cohérence comportementale et la valeur ajoutée visible pour les autres.\n\nCe module final consolide l'ensemble du programme. Vous êtes maintenant prêt à passer l'évaluation de certification.`,
  M08: `La comptabilité est la langue des affaires. Comprendre les bases comptables vous permet de piloter votre activité avec précision, d'anticiper les difficultés et de communiquer efficacement avec vos partenaires financiers.\n\nLes trois documents fondamentaux : le compte de résultat (performance sur une période), le bilan (situation patrimoniale à un instant T) et le tableau de flux de trésorerie (mouvements de liquidités).\n\nMaîtriser ces documents vous donne un avantage concurrentiel majeur face aux entrepreneurs qui sous-traitent totalement la lecture financière de leur entreprise.`,
  M09: `Le bilan comptable est une photographie de votre entreprise à une date donnée. Il se compose de l'actif (ce que vous possédez) et du passif (la façon dont vos actifs sont financés).\n\nSavoir lire un bilan permet de détecter rapidement les signaux d'alerte : ratio d'endettement excessif, manque de fonds propres, immobilisations mal financées. C'est un outil de diagnostic indispensable.\n\nExercice pratique : procurez-vous le dernier bilan de votre entreprise (ou d'une entreprise de référence) et identifiez les 5 postes les plus importants de l'actif et du passif.`,
  M10: `L'optimisation fiscale légale consiste à utiliser les dispositifs prévus par la loi pour minimiser la charge fiscale de votre entreprise. Elle est fondamentalement différente de la fraude fiscale.\n\nPrincipales leviers d'optimisation : le choix de la forme juridique, le régime fiscal adapté, la gestion des charges déductibles, les provisions réglementées, et les dispositifs d'investissement bénéficiant d'avantages fiscaux.\n\nUn expert-comptable compétent peut vous faire économiser plusieurs milliers d'euros par an. Considérez-le comme un investissement, pas une dépense.`,
  M11: `Ce module d'évaluation finale synthétise l'ensemble des compétences acquises dans cette formation sur l'optimisation fiscale pour TPE/PME.\n\nVous avez appris à lire les états financiers, à comprendre les mécanismes de la TVA, à identifier les charges déductibles et à développer une stratégie fiscale cohérente avec vos objectifs d'entreprise.\n\nPassez maintenant l'évaluation finale pour valider votre certificat de formation.`,
};

const typeIcon: Record<string, string> = {
  "Vidéo": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>`,
  "Document": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v14a2 2 0 01-2 2z"/></svg>`,
  "Quiz": `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
};

const modulesIds = cours.modules.map(m => m.id);
const firstUndoneIndex = modulesIds.findIndex(mid => !modulesTermines.includes(mid));
const defaultOpenId = firstUndoneIndex >= 0 ? modulesIds[firstUndoneIndex] : modulesIds[modulesIds.length - 1];

const quizByModule = await Promise.all(
  cours.modules.map(async (m) => [m.id, await getQuizQuestions(m.id)] as const)
);
const quizData = Object.fromEntries(
  quizByModule.map(([id, questions]) => [
    id,
    questions.map((q) => ({ id: q.id, question: q.question, options: q.options, correcte: q.correcte })),
  ])
) as Record<string, { id: string; question: string; options: string[]; correcte: number }[]>;

function moduleHasQuiz(moduleId: string): boolean {
  return (quizData[moduleId] ?? []).length > 0;
}
---

<AdherentMemberLayout titre={cours.titre}>

  <div class="flex items-center gap-2 mb-6 text-xs text-gray-400">
    <a href="/adherent/cours" class="hover:underline" style="color: #d4a762;">Mes cours</a>
    <span>/</span>
    <span style="color: #0b1f3a;">{cours.titre}</span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">

    <div class="lg:col-span-2 flex flex-col gap-2" id="modules-container">
      {cours.modules.map((mod) => {
        const termine = modulesTermines.includes(mod.id);
        const quizRes = quizResultats.find(q => q.moduleId === mod.id);
        const isOpen = mod.id === defaultOpenId;
        const contenu = contenuParModule[mod.id];
        const hasQuiz = moduleHasQuiz(mod.id);
        return (
          <div
            class="module-item rounded-2xl overflow-hidden transition-all"
            style={termine ? "border: 1px solid rgba(22,163,74,0.2);" : isOpen ? "border: 1px solid #d4a762; box-shadow: 0 2px 12px rgba(212,167,98,0.15);" : "border: 1px solid #f1f3f5;"}
            data-module-id={mod.id}
          >
            <button class="module-header w-full flex items-center gap-4 p-4 text-left transition hover:bg-gray-50/50" data-target={mod.id}>
              <div
                class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold"
                style={termine ? "background-color: #16a34a; color: white;" : isOpen ? "background-color: #0b1f3a; color: white;" : "background-color: #f1f3f5; color: #9ca3af;"}
              >
                {termine
                  ? <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                  : <span>{mod.ordre}</span>
                }
              </div>
              <div class="flex-1 min-w-0 text-left">
                <p class="text-sm font-semibold" style="color: #0b1f3a;">{mod.titre}</p>
                <div class="flex items-center gap-2 mt-0.5 text-xs text-gray-400">
                  <span class="flex items-center gap-1" set:html={`${typeIcon[mod.type] ?? ""} ${mod.type}`} />
                  <span>·</span>
                  <span>{mod.duree}</span>
                  {hasQuiz && <span>· <strong style="color: #d4a762;">Quiz inclus</strong></span>}
                </div>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                {termine && quizRes && (
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full" style="background-color: rgba(22,163,74,0.1); color: #16a34a;">
                    {quizRes.score}%
                  </span>
                )}
                {termine && <span class="text-xs font-medium" style="color: #16a34a;">Terminé</span>}
                <svg class="module-chevron transition-transform duration-200" style={isOpen ? "transform: rotate(180deg);" : ""} xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </button>

            <div class="module-content" style={isOpen ? "display: block;" : "display: none;"}>
              <div class="px-4 pb-5 pt-1">
                <div class="rounded-xl p-5" style="background-color: #f8f6f2;">

                  {mod.type === "Vidéo" && (
                    <div>
                      <div class="flex flex-col items-center justify-center gap-3 py-10 rounded-xl mb-4" style="background-color: #0b1f3a;">
                        <div class="w-14 h-14 rounded-full flex items-center justify-center" style="background-color: rgba(212,167,98,0.2);">
                          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.8"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        </div>
                        <p class="text-sm font-medium text-white">{mod.titre}</p>
                        <p class="text-xs" style="color: rgba(255,255,255,0.4);">{mod.duree}</p>
                      </div>
                      {contenu && <div class="text-sm leading-relaxed space-y-3" style="color: #374151;">{contenu.split("\n\n").map(para => <p>{para}</p>)}</div>}
                    </div>
                  )}

                  {mod.type === "Document" && (
                    <div>
                      {contenu && <div class="text-sm leading-relaxed space-y-3 mb-5" style="color: #374151;">{contenu.split("\n\n").map(para => <p>{para}</p>)}</div>}
                      <div class="flex items-center gap-3 p-3 bg-white rounded-xl shadow-sm">
                        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" style="background-color: rgba(212,167,98,0.1);">
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5l5 5v14a2 2 0 01-2 2z"/></svg>
                        </div>
                        <div class="flex-1 min-w-0">
                          <p class="text-sm font-medium truncate" style="color: #0b1f3a;">{mod.titre} — Support de cours</p>
                          <p class="text-xs text-gray-400">Document PDF · {mod.duree} de lecture</p>
                        </div>
                        <span class="text-xs font-medium px-3 py-1.5 rounded-lg" style="background-color: #f1f3f5; color: #9ca3af;">Bientôt dispo</span>
                      </div>
                    </div>
                  )}

                  {mod.type === "Quiz" && contenu && (
                    <div class="text-sm leading-relaxed space-y-3 mb-4" style="color: #374151;">
                      {contenu.split("\n\n").map(para => <p>{para}</p>)}
                    </div>
                  )}

                  <!-- Bouton quiz / déjà terminé -->
                  {!termine && hasQuiz && (
                    <div class="mt-4 pt-4" style="border-top: 1px solid rgba(0,0,0,0.06);">
                      <button
                        class="btn-faire-quiz w-full py-2.5 rounded-xl text-sm font-semibold transition hover:opacity-90"
                        style="background-color: #d4a762; color: #0b1f3a;"
                        data-cours-id={cours.id}
                        data-module-id={mod.id}
                      >
                        Faire le quiz
                      </button>
                    </div>
                  )}
                  {!termine && !hasQuiz && (
                    <div class="mt-4 pt-4" style="border-top: 1px solid rgba(0,0,0,0.06);">
                      <button
                        class="btn-marquer-termine w-full py-2.5 rounded-xl text-sm font-semibold text-white transition hover:opacity-90"
                        style="background-color: #0b1f3a;"
                        data-cours-id={cours.id}
                        data-module-id={mod.id}
                      >
                        Marquer comme terminé
                      </button>
                    </div>
                  )}
                  {termine && quizRes && (
                    <div class="mt-4 pt-4" style="border-top: 1px solid rgba(0,0,0,0.06);">
                      <div class="rounded-xl px-4 py-3 text-sm" style="background-color: rgba(22,163,74,0.08);">
                        <p class="font-semibold" style="color: #16a34a;">Quiz réussi — {quizRes.score}%</p>
                        <button class="btn-faire-quiz text-xs underline mt-1" style="color: #6b7280;" data-cours-id={cours.id} data-module-id={mod.id}>
                          Refaire le quiz
                        </button>
                      </div>
                    </div>
                  )}

                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Sidebar -->
    <div class="flex flex-col gap-4 lg:sticky lg:top-6">
      <div class="bg-white rounded-2xl p-5 shadow-sm" style="border: 1px solid #f1f3f5;">
        <h4 class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-4">Votre progression</h4>
        <div class="flex items-center justify-center mb-3">
          <div class="relative w-24 h-24">
            <svg class="w-24 h-24 -rotate-90" viewBox="0 0 96 96">
              <circle cx="48" cy="48" r="38" fill="none" stroke="#f1f3f5" stroke-width="8"/>
              <circle cx="48" cy="48" r="38" fill="none" stroke={pourcentage === 100 ? "#16a34a" : "#d4a762"} stroke-width="8" stroke-linecap="round"
                stroke-dasharray={`${2 * Math.PI * 38}`}
                stroke-dashoffset={`${2 * Math.PI * 38 * (1 - pourcentage / 100)}`}
              />
            </svg>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-xl font-bold" style={pourcentage === 100 ? "color: #16a34a;" : "color: #0b1f3a;"}>{pourcentage}%</span>
            </div>
          </div>
        </div>
        <p class="text-center text-xs text-gray-400">{modulesTermines.length} / {cours.modules.length} modules</p>
        {coursTermine && (
          <div class="mt-3 p-3 rounded-xl text-center" style="background-color: rgba(22,163,74,0.08);">
            <p class="text-xs font-semibold" style="color: #16a34a;">Formation complétée !</p>
            <a href="/adherent/certificats" class="text-xs underline mt-1 block" style="color: #16a34a;">Voir mon certificat</a>
          </div>
        )}
      </div>

      <div class="bg-white rounded-2xl p-5 shadow-sm" style="border: 1px solid #f1f3f5;">
        <h4 class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-4">À propos du cours</h4>
        <div class="flex flex-col gap-3 text-xs">
          <div class="flex items-center justify-between">
            <span class="text-gray-400">Niveau</span>
            <Badge variant={(cours.niveau as string) === "Débutant" ? "or" : (cours.niveau as string) === "Intermédiaire" ? "vert" : "gris"}>{cours.niveau}</Badge>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-400">Durée totale</span>
            <span class="font-medium" style="color: #0b1f3a;">{cours.duree}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-400">Modules</span>
            <span class="font-medium" style="color: #0b1f3a;">{cours.modules.length}</span>
          </div>
        </div>
      </div>

      <a href="/adherent/cours" class="flex items-center gap-2 text-sm font-medium transition hover:opacity-70" style="color: #d4a762;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux cours
      </a>
    </div>

  </div>

</AdherentMemberLayout>

<!-- MODAL QUIZ -->
<div id="modal-quiz" class="fixed inset-0 z-50 hidden items-center justify-center" style="background: rgba(0,0,0,0.5);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg mx-4 max-h-[90vh] overflow-y-auto">
    <div class="flex items-center justify-between px-6 pt-6 pb-4" style="border-bottom: 1px solid #f1f3f5;">
      <div>
        <h3 id="quiz-titre" class="text-lg font-bold" style="color: #0b1f3a;">Quiz du module</h3>
        <p class="text-xs text-gray-400 mt-0.5">Répondez à toutes les questions. Score minimum : 80%</p>
      </div>
      <button id="quiz-close" class="text-gray-400 hover:text-gray-600 text-xl font-bold">×</button>
    </div>
    <div id="quiz-body" class="px-6 py-5">
      <!-- questions injectées dynamiquement -->
    </div>
    <!-- Résultat -->
    <div id="quiz-result" class="hidden px-6 pb-6">
      <div id="quiz-result-content" class="rounded-2xl p-6 text-center"></div>
      <div class="flex gap-3 mt-4">
        <button id="quiz-retry" class="flex-1 py-2.5 rounded-xl text-sm font-semibold" style="background-color: #f1f3f5; color: #0b1f3a;">Réessayer</button>
        <button id="quiz-continue" class="flex-1 py-2.5 rounded-xl text-sm font-semibold text-white" style="background-color: #16a34a;">Continuer</button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ quizData, coursId: cours.id }}>
(function() {
  // Accordéon
  document.querySelectorAll(".module-header").forEach(btn => {
    btn.addEventListener("click", function() {
      const targetId = this.dataset.target;
      document.querySelectorAll(".module-item").forEach(item => {
        const content = item.querySelector(".module-content");
        const chevron = item.querySelector(".module-chevron");
        if (item.dataset.moduleId === targetId) {
          const open = content.style.display !== "none";
          content.style.display = open ? "none" : "block";
          chevron.style.transform = open ? "" : "rotate(180deg)";
        }
      });
    });
  });

  // Marquer terminé (sans quiz)
  document.querySelectorAll(".btn-marquer-termine").forEach(btn => {
    btn.addEventListener("click", async function() {
      this.disabled = true;
      this.textContent = "Enregistrement…";
      const res = await fetch("/api/progression", {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ coursId: this.dataset.coursId, moduleId: this.dataset.moduleId }),
      });
      if (res.ok) location.reload();
      else { this.disabled = false; this.textContent = "Marquer comme terminé"; }
    });
  });

  // Modal quiz
  const modal = document.getElementById("modal-quiz");
  const quizBody = document.getElementById("quiz-body");
  const quizResult = document.getElementById("quiz-result");
  const quizResultContent = document.getElementById("quiz-result-content");
  const quizTitre = document.getElementById("quiz-titre");
  let currentModuleId = null;
  let currentReponses = [];

  function openModal(moduleId) {
    currentModuleId = moduleId;
    const questions = quizData[moduleId] || [];
    quizTitre.textContent = "Quiz — " + (questions[0] ? "Module en cours" : moduleId);
    quizBody.innerHTML = "";
    quizResult.classList.add("hidden");

    questions.forEach((q, qi) => {
      const div = document.createElement("div");
      div.className = "mb-6";
      div.innerHTML = `
        <p class="text-sm font-semibold mb-3" style="color:#0b1f3a;">${qi+1}. ${q.question}</p>
        <div class="flex flex-col gap-2" id="options-${qi}">
          ${q.options.map((opt, oi) => `
            <label class="quiz-option flex items-center gap-3 p-3 rounded-xl cursor-pointer transition" style="border: 1.5px solid #f1f3f5;" data-qi="${qi}" data-oi="${oi}">
              <span class="w-5 h-5 rounded-full border-2 flex-shrink-0 flex items-center justify-center text-xs font-bold" style="border-color: #d1d5db;" id="dot-${qi}-${oi}"></span>
              <span class="text-sm" style="color:#374151;">${opt}</span>
            </label>
          `).join("")}
        </div>
      `;
      quizBody.appendChild(div);
    });

    // Submit button
    const submitDiv = document.createElement("div");
    submitDiv.innerHTML = `
      <p id="quiz-err" class="text-red-500 text-xs hidden mb-2">Répondez à toutes les questions avant de valider.</p>
      <button id="quiz-submit" class="w-full py-3 rounded-xl text-sm font-bold text-white transition hover:opacity-90" style="background-color:#d4a762; color:#0b1f3a;">
        Valider mes réponses
      </button>
    `;
    quizBody.appendChild(submitDiv);

    // Option selection
    currentReponses = new Array(questions.length).fill(-1);
    quizBody.querySelectorAll(".quiz-option").forEach(label => {
      label.addEventListener("click", function() {
        const qi = parseInt(this.dataset.qi);
        const oi = parseInt(this.dataset.oi);
        currentReponses[qi] = oi;
        // Reset same-question options
        quizBody.querySelectorAll(`.quiz-option[data-qi="${qi}"]`).forEach(l => {
          l.style.borderColor = "#f1f3f5";
          l.style.backgroundColor = "";
          l.querySelector("span").style.borderColor = "#d1d5db";
          l.querySelector("span").style.backgroundColor = "";
        });
        // Highlight selected
        this.style.borderColor = "#d4a762";
        this.style.backgroundColor = "rgba(212,167,98,0.06)";
        const dot = this.querySelector("span");
        dot.style.borderColor = "#d4a762";
        dot.style.backgroundColor = "#d4a762";
        dot.textContent = "✓";
      });
    });

    document.getElementById("quiz-submit").addEventListener("click", submitQuiz);

    modal.classList.remove("hidden");
    modal.classList.add("flex");
  }

  async function submitQuiz() {
    const questions = quizData[currentModuleId] || [];
    const err = document.getElementById("quiz-err");
    if (currentReponses.some(r => r === -1)) {
      err.classList.remove("hidden");
      return;
    }
    err.classList.add("hidden");
    const btn = document.getElementById("quiz-submit");
    btn.disabled = true;
    btn.textContent = "Correction…";

    const res = await fetch("/api/quiz", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ coursId, moduleId: currentModuleId, reponses: currentReponses }),
    });
    const data = await res.json();

    quizBody.style.display = "none";
    quizResult.classList.remove("hidden");

    const retryBtn = document.getElementById("quiz-retry");
    const continueBtn = document.getElementById("quiz-continue");

    if (data.passe) {
      quizResultContent.innerHTML = `
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background-color: rgba(22,163,74,0.1);">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#16a34a" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h4 class="text-xl font-bold mb-1" style="color:#16a34a;">Félicitations !</h4>
        <p class="text-sm text-gray-500 mb-3">Score : <strong style="color:#0b1f3a;">${data.score}%</strong> — ${data.bonnes}/${data.total} bonnes réponses</p>
        <p class="text-xs text-gray-400">Ce module est maintenant validé.</p>
      `;
      quizResultContent.style.backgroundColor = "rgba(22,163,74,0.05)";
      retryBtn.style.display = "none";
      continueBtn.style.display = "";
      continueBtn.textContent = "Continuer →";
    } else {
      quizResultContent.innerHTML = `
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background-color: rgba(220,38,38,0.08);">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#dc2626" stroke-width="2"><circle cx="12" cy="12" r="9"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>
        </div>
        <h4 class="text-xl font-bold mb-1" style="color:#dc2626;">Pas encore !</h4>
        <p class="text-sm text-gray-500 mb-1">Score : <strong style="color:#0b1f3a;">${data.score}%</strong> — ${data.bonnes}/${data.total} bonnes réponses</p>
        <p class="text-xs text-gray-400">Il faut <strong>80%</strong> minimum pour valider. Relisez le module et réessayez.</p>
      `;
      quizResultContent.style.backgroundColor = "rgba(220,38,38,0.03)";
      retryBtn.style.display = "";
      continueBtn.style.display = "none";
    }
  }

  document.getElementById("quiz-retry").addEventListener("click", () => {
    // Remettre les boutons dans leur état initial avant de relancer
    document.getElementById("quiz-retry").style.display = "";
    document.getElementById("quiz-continue").style.display = "";
    quizBody.style.display = "";
    quizResult.classList.add("hidden");
    openModal(currentModuleId);
  });

  document.getElementById("quiz-continue").addEventListener("click", () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    location.reload();
  });

  document.getElementById("quiz-close").addEventListener("click", () => {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  });

  document.querySelectorAll(".btn-faire-quiz").forEach(btn => {
    btn.addEventListener("click", () => openModal(btn.dataset.moduleId));
  });
})();
</script>
