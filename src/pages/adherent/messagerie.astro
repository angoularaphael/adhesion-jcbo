---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import { getAdherentByEmail, findOrCreateConversation, markAsReadAdherent } from "../../lib/store";

const profil = await getAdherentByEmail(Astro.locals.session?.email ?? "");
if (!profil) return Astro.redirect("/login");

const conv = await findOrCreateConversation(profil.email, "Messagerie adhérent");
await markAsReadAdherent(conv.id);
const messages = conv.messages;
---

<AdherentMemberLayout titre="Messagerie">

  <div class="mb-6">
    <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Messagerie</h2>
    <p class="text-sm text-gray-500 mt-1">Échangez directement avec l'équipe JCBO Conseil.</p>
  </div>

  <div class="max-w-2xl">
    <Card>
      <!-- En-tête conversation -->
      <div class="flex items-center gap-3 pb-4 mb-4" style="border-bottom: 1px solid #f1f3f5;">
        <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 text-sm font-bold text-white" style="background-color: #0b1f3a;">
          JC
        </div>
        <div>
          <p class="text-sm font-semibold" style="color: #0b1f3a;">JCBO Conseil</p>
          <p class="text-xs text-gray-400">Équipe administrative</p>
        </div>
        <div class="ml-auto flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-green-400"></span>
          <span class="text-xs text-gray-400">En ligne</span>
        </div>
      </div>

      <!-- Zone de messages -->
      <div id="messages-container" class="flex flex-col gap-3 min-h-48 max-h-[50vh] sm:min-h-64 sm:max-h-96 overflow-y-auto px-1 pb-2">
        {messages.length === 0 && (
          <div class="flex flex-col items-center justify-center py-16 text-center">
            <div class="w-14 h-14 rounded-full flex items-center justify-center mb-3" style="background-color: rgba(212,167,98,0.1);">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4-4 7-9 7a9.9 9.9 0 01-4-.8L3 20l1.8-4A7 7 0 013 12c0-4 4-7 9-7s9 3 9 7z"/></svg>
            </div>
            <p class="text-sm font-medium" style="color: #0b1f3a;">Aucun message pour le moment</p>
            <p class="text-xs text-gray-400 mt-1">Envoyez votre premier message à l'équipe JCBO Conseil.</p>
          </div>
        )}
        {messages.map(msg => (
          <div class={`flex ${msg.de === "adherent" ? "justify-end" : "justify-start"}`}>
            <div
              class="max-w-[75%] sm:max-w-xs lg:max-w-sm rounded-2xl px-4 py-2.5 text-sm"
              style={msg.de === "adherent"
                ? "background-color: #0b1f3a; color: white; border-bottom-right-radius: 4px;"
                : "background-color: #f8f6f2; color: #374151; border-bottom-left-radius: 4px;"}
            >
              <p class="leading-relaxed whitespace-pre-wrap">{msg.texte}</p>
              <p class="text-xs mt-1 text-right" style={msg.de === "adherent" ? "color: rgba(255,255,255,0.4);" : "color: #9ca3af;"}>{msg.heure}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Zone de saisie -->
      <div class="mt-4 pt-4" style="border-top: 1px solid #f1f3f5;">
        <div class="flex gap-3">
          <textarea
            id="msg-input"
            rows="2"
            placeholder="Écrivez votre message…"
            class="flex-1 border border-gray-200 rounded-xl px-4 py-2.5 text-sm resize-none focus:outline-none focus:border-yellow-400 transition"
          ></textarea>
          <button
            id="msg-send"
            class="px-5 rounded-xl text-sm font-semibold text-white flex-shrink-0 transition hover:opacity-90 active:scale-[0.98]"
            style="background-color: #d4a762; color: #0b1f3a;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
        <p id="msg-error" class="text-red-500 text-xs mt-2 hidden"></p>
      </div>
    </Card>
  </div>

</AdherentMemberLayout>

<script is:inline define:vars={{ convId: conv.id }}>
(function() {
  const container = document.getElementById("messages-container");
  const input = document.getElementById("msg-input");
  const sendBtn = document.getElementById("msg-send");
  const errorEl = document.getElementById("msg-error");

  // Scroll to bottom
  container.scrollTop = container.scrollHeight;

  function addBubble(texte, de) {
    const div = document.createElement("div");
    div.className = "flex " + (de === "adherent" ? "justify-end" : "justify-start");
    const now = new Date();
    const heure = now.getHours().toString().padStart(2,"0") + ":" + now.getMinutes().toString().padStart(2,"0");
    div.innerHTML = `
      <div class="max-w-[75%] sm:max-w-xs lg:max-w-sm rounded-2xl px-4 py-2.5 text-sm"
        style="${de === "adherent"
          ? "background-color:#0b1f3a;color:white;border-bottom-right-radius:4px;"
          : "background-color:#f8f6f2;color:#374151;border-bottom-left-radius:4px;"}"
      >
        <p class="leading-relaxed whitespace-pre-wrap">${texte.replace(/</g,"&lt;")}</p>
        <p class="text-xs mt-1 text-right" style="${de === "adherent" ? "color:rgba(255,255,255,0.4);" : "color:#9ca3af;"}">${heure}</p>
      </div>
    `;
    // Remove empty state if present
    const empty = container.querySelector(".flex.flex-col.items-center");
    if (empty) empty.remove();
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
  }

  async function sendMessage() {
    const texte = input.value.trim();
    if (!texte) return;
    errorEl.classList.add("hidden");
    sendBtn.disabled = true;

    try {
      const res = await fetch(`/api/messagerie/${convId}/messages`, {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ texte, de: "adherent" }),
      });
      const data = await res.json();
      if (!res.ok) { errorEl.textContent = data.error || "Erreur"; errorEl.classList.remove("hidden"); return; }
      addBubble(texte, "adherent");
      input.value = "";
    } catch {
      errorEl.textContent = "Erreur réseau";
      errorEl.classList.remove("hidden");
    } finally {
      sendBtn.disabled = false;
    }
  }

  sendBtn.addEventListener("click", sendMessage);
  input.addEventListener("keydown", e => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
})();
</script>
