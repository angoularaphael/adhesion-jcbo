---
import "../styles/global.css";
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Connexion — JCBO Conseil</title>
  </head>

  <body class="min-h-screen flex items-center justify-center" style="background-color: #0D1B2A;">

    <div class="w-full max-w-md px-6">

      <div class="text-center mb-10">
        <h1 class="text-2xl font-bold tracking-wide text-white">JCBO Conseil</h1>
        <p class="text-sm mt-1" style="color: #C9A84C;">Espace Adhérent</p>
      </div>

      <div class="bg-white rounded-2xl shadow-xl p-8">
        <h2 class="text-lg font-semibold mb-6" style="color: #0D1B2A;">Connexion</h2>

        <form id="login-form" class="flex flex-col gap-5">

          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium text-gray-700">Adresse e-mail</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="vous@exemple.fr"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition"
              style="color: #0D1B2A;"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="password" class="text-sm font-medium text-gray-700">Mot de passe</label>
            <input
              id="password"
              name="password"
              type="password"
              required
              placeholder="••••••••"
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition"
              style="color: #0D1B2A;"
            />
          </div>

          <button
            type="submit"
            class="w-full py-2.5 rounded-lg text-sm font-semibold text-white transition hover:opacity-90 active:scale-[0.98]"
            style="background-color: #0D1B2A;"
          >
            Se connecter
          </button>

        </form>

        <p class="text-xs text-gray-400 text-center mt-6">
          Problème de connexion ? <a href="mailto:contact@jcbo-conseil.fr" class="underline hover:text-gray-600">Contactez-nous</a>
        </p>
      </div>

    </div>

    <script>
      document.getElementById("login-form").addEventListener("submit", (e) => {
        e.preventDefault();
        window.location.href = "/dashboard";
      });
    </script>

  </body>
</html>
