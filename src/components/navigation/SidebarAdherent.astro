---
import LogoJCBO from "../ui/LogoJCBO.astro";
import { getAdherentByEmail, getConversations, getNonLuCount } from "../../lib/store";

const email = Astro.locals.session?.email ?? "";
const profil = getAdherentByEmail(email);
const initiales = profil ? (profil.prenom[0] + profil.nom[0]).toUpperCase() : "?";

const conv = email ? getConversations().find(c => c.email === email.toLowerCase()) : null;
const nonLuAdherent = conv?.non_lu_adherent ?? 0;
const notifsNonLues = email ? getNonLuCount(email) : 0;

const navLinks = [
  {
    label: "Tableau de bord",
    href: "/adherent/tableau-de-bord",
    badge: 0,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
  },
  {
    label: "Mon profil",
    href: "/adherent/profil",
    badge: 0,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>`,
  },
  {
    label: "Mes cours",
    href: "/adherent/cours",
    badge: 0,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>`,
  },
  {
    label: "Mes certificats",
    href: "/adherent/certificats",
    badge: 0,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="9" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M9 21l3-3 3 3V15a6 6 0 10-6 0v6z"/></svg>`,
  },
  {
    label: "Messagerie",
    href: "/adherent/messagerie",
    badge: nonLuAdherent,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4-4 7-9 7a9.9 9.9 0 01-4-.8L3 20l1.8-4A7 7 0 013 12c0-4 4-7 9-7s9 3 9 7z"/></svg>`,
  },
  {
    label: "Paiements",
    href: "/adherent/paiements",
    badge: notifsNonLues,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
  },
  {
    label: "Mon abonnement",
    href: "/adherent/abonnement",
    badge: 0,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10" stroke-linecap="round"/></svg>`,
  },
  {
    label: "Ressources",
    href: "/adherent/ressources",
    badge: 0,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/></svg>`,
  },
  {
    label: "Contact",
    href: "/adherent/contact",
    badge: 0,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
];

const currentPath = Astro.url.pathname;
---

<aside id="sidebar-adherent" class="w-64 min-h-screen flex flex-col flex-shrink-0 fixed lg:static inset-y-0 left-0 z-[60] -translate-x-full lg:translate-x-0 transition-transform duration-300" style="background-color: #0b1f3a;">

  <!-- Logo + label -->
  <div class="px-6 py-6 flex items-center gap-3" style="border-bottom: 1px solid rgba(212,167,98,0.15);">
    <LogoJCBO size={44} />
    <div>
      <p class="text-sm font-semibold text-white tracking-wide">JCBO Conseil</p>
      <p class="text-xs mt-0.5" style="color: #d4a762;">Espace Adhérent</p>
    </div>
  </div>

  <!-- Membre connecté -->
  <div class="px-6 py-4 flex items-center gap-3" style="border-bottom: 1px solid rgba(212,167,98,0.08);">
    <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0" style="background-color: rgba(212,167,98,0.2); color: #d4a762;">
      {initiales}
    </div>
    <div class="min-w-0">
      <p class="text-sm font-medium text-white truncate">{profil?.prenom} {profil?.nom}</p>
      <p class="text-xs truncate" style="color: rgba(255,255,255,0.35);">{profil?.entreprise || "Adhérent"}</p>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="flex-1 px-3 py-5 flex flex-col gap-0.5">
    {navLinks.map((link) => {
      const isActive = currentPath === link.href || currentPath.startsWith(link.href + "/");
      return (
        <a
          href={link.href}
          class={`relative flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 ${
            isActive ? "text-white" : "hover:text-white hover:bg-white/5"
          }`}
          style={isActive ? "background-color: rgba(212,167,98,0.12); color: #d4a762;" : "color: rgba(255,255,255,0.55);"}
        >
          {isActive && (
            <span class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-5 rounded-r-full" style="background-color: #d4a762;"></span>
          )}
          <span class="flex-shrink-0" set:html={link.icon} />
          <span class="flex-1">{link.label}</span>
          {link.badge > 0 && (
            <span class="ml-auto min-w-[20px] h-5 rounded-full text-xs font-bold flex items-center justify-center px-1.5" style="background-color: #d4a762; color: #0b1f3a;">
              {link.badge > 99 ? "99+" : link.badge}
            </span>
          )}
        </a>
      );
    })}
  </nav>

  <!-- Déconnexion -->
  <div class="px-3 py-5" style="border-top: 1px solid rgba(212,167,98,0.15);">
    <button id="btn-logout-adherent"
      class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 hover:bg-white/5 w-full text-left"
      style="color: rgba(255,255,255,0.4);"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h6a2 2 0 012 2v1"/>
      </svg>
      <span>Déconnexion</span>
    </button>
  </div>

  <script>
    document.getElementById("btn-logout-adherent")?.addEventListener("click", async () => {
      await fetch("/api/auth/logout", { method: "DELETE" }).catch(() => {});
      window.location.href = "/login";
    });
  </script>

</aside>

<div id="sidebar-overlay-adherent" class="fixed inset-0 z-[50] bg-black/50 hidden lg:hidden" onclick="document.getElementById('sidebar-adherent').classList.add('-translate-x-full'); this.classList.add('hidden');"></div>
