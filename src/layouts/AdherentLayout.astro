---
import Sidebar from "../components/navigation/Sidebar.astro";
import Header from "../components/navigation/Header.astro";
import "../styles/global.css";
import { getConversations } from "../lib/store";

interface Props {
  titre: string;
}
const { titre } = Astro.props;
const totalNonLuAdmin = getConversations().reduce((sum, c) => sum + c.non_lu, 0);
const currentPathAdmin = Astro.url.pathname;
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="Espace d'administration JCBO Conseil — gestion des adhérents, actualités et messagerie." />
    <title>{titre} — JCBO Conseil</title>
    <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "JCBO Conseil",
      "description": "Cabinet de conseil aux entreprises spécialisé en accompagnement stratégique, fiscal et organisationnel.",
      "url": "https://jcboyang-conseil-1.onrender.com"
    }
    </script>
  </head>

  <body class="flex" style="background-color: #f8f6f2; min-height: 100vh;">

    <Sidebar />

    <div class="flex flex-col flex-1 min-w-0">
      <Header>
        <!-- Hamburger mobile -->
        <div class="flex items-center gap-3">
          <button id="menu-toggle" class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition" style="color: #0b1f3a;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <h1 class="text-lg font-semibold font-heading" style="color: #0b1f3a;">{titre}</h1>
        </div>
      </Header>

      <main class="p-4 lg:p-8 flex-1 pb-24 lg:pb-8">
        <slot />
      </main>
    </div>

    <!-- Barre de navigation mobile admin (bas d'écran) -->
    <nav class="fixed bottom-0 left-0 right-0 z-40 lg:hidden flex items-stretch border-t border-gray-800" style="background-color: #0b1f3a; height: 64px;">
      {[
        { href: "/dashboard", label: "Dashboard", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`, badge: 0 },
        { href: "/dashboard/messagerie", label: "Messages", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4-4 7-9 7a9.9 9.9 0 01-4-.8L3 20l1.8-4A7 7 0 013 12c0-4 4-7 9-7s9 3 9 7z"/></svg>`, badge: totalNonLuAdmin },
        { href: "/dashboard/adherents", label: "Adhérents", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="7" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-2a4 4 0 014-4h4a4 4 0 014 4v2M16 3.13a4 4 0 010 7.75M21 21v-2a4 4 0 00-3-3.87"/></svg>`, badge: 0 },
        { href: "/dashboard/paiements", label: "Paiements", icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`, badge: 0 },
      ].map(link => {
        const isActive = currentPathAdmin === link.href || (link.href !== "/dashboard" && currentPathAdmin.startsWith(link.href));
        return (
          <a href={link.href} class="relative flex-1 flex flex-col items-center justify-center gap-1 transition-all duration-200"
            style={isActive ? "color: #d4a762;" : "color: rgba(255,255,255,0.45);"}>
            {isActive && <span class="absolute top-0 left-1/2 -translate-x-1/2 w-8 h-0.5 rounded-full" style="background-color: #d4a762;"></span>}
            {link.badge > 0 && (
              <span class="absolute top-2 right-1/4 w-4 h-4 rounded-full flex items-center justify-center text-[10px] font-bold" style="background-color: #d4a762; color: #0b1f3a;">{link.badge > 9 ? "9+" : link.badge}</span>
            )}
            <span set:html={link.icon} />
            <span class="text-[10px] font-medium">{link.label}</span>
          </a>
        );
      })}
      <button id="admin-menu-btn" class="flex-1 flex flex-col items-center justify-center gap-1 transition-all duration-200" style="color: rgba(255,255,255,0.45);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <span class="text-[10px] font-medium">Menu</span>
      </button>
    </nav>

    <script>
      const toggle = document.getElementById("menu-toggle");
      const adminMenuBtn = document.getElementById("admin-menu-btn");
      const sidebar = document.getElementById("sidebar");
      const overlay = document.getElementById("sidebar-overlay");
      function openAdminSidebar() {
        sidebar?.classList.remove("-translate-x-full");
        overlay?.classList.remove("hidden");
      }
      toggle?.addEventListener("click", openAdminSidebar);
      adminMenuBtn?.addEventListener("click", openAdminSidebar);
      overlay?.addEventListener("click", () => {
        sidebar?.classList.add("-translate-x-full");
        overlay?.classList.add("hidden");
      });
    </script>

  </body>
</html>

