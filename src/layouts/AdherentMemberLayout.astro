---
import SidebarAdherent from "../components/navigation/SidebarAdherent.astro";
import "../styles/global.css";
import { getAdherentByEmail, getConversations, getNonLuCount } from "../lib/store";

interface Props {
  titre: string;
}
const { titre } = Astro.props;
const email = Astro.locals.session?.email ?? "";
const profil = getAdherentByEmail(email);
const initiales = profil ? (profil.prenom[0] + profil.nom[0]).toUpperCase() : "?";

const conv = email ? getConversations().find(c => c.email === email.toLowerCase()) : null;
const msgNonLus = conv?.non_lu_adherent ?? 0;
const notifsNonLues = email ? getNonLuCount(email) : 0;
const currentPath = Astro.url.pathname;
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{titre} — Espace Adhérent JCBO</title>
  </head>

  <body class="flex" style="background-color: #f8f6f2; min-height: 100vh;">

    <SidebarAdherent />

    <div class="flex flex-col flex-1 min-w-0">

      <header class="h-16 flex items-center justify-between px-6 lg:px-8 bg-white border-b border-gray-100 flex-shrink-0">
        <div class="flex items-center gap-3">
          <button id="menu-toggle" class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition" style="color: #0b1f3a;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
          <h1 class="text-lg font-semibold font-heading" style="color: #0b1f3a;">{titre}</h1>
        </div>
        <div class="flex items-center gap-3">
          <div class="text-right hidden sm:block">
            <p class="text-sm font-semibold" style="color: #0b1f3a;">{profil?.prenom} {profil?.nom}</p>
            <p class="text-xs text-gray-400">{profil?.entreprise}</p>
          </div>
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0" style="background-color: rgba(212,167,98,0.15); color: #d4a762;">
            {initiales}
          </div>
        </div>
      </header>

      <main class="p-4 lg:p-8 flex-1 pb-24 lg:pb-8">
        <slot />
      </main>

    </div>

    <!-- Barre de navigation mobile (bas d'écran) -->
    <nav class="fixed bottom-0 left-0 right-0 z-40 lg:hidden flex items-stretch border-t border-gray-200" style="background-color: #0b1f3a; height: 64px;">
      {[
        { href: "/adherent/tableau-de-bord", label: "Accueil", badge: 0, icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>` },
        { href: "/adherent/cours", label: "Cours", badge: 0, icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/></svg>` },
        { href: "/adherent/messagerie", label: "Messages", badge: msgNonLus, icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M21 12c0 4-4 7-9 7a9.9 9.9 0 01-4-.8L3 20l1.8-4A7 7 0 013 12c0-4 4-7 9-7s9 3 9 7z"/></svg>` },
        { href: "/adherent/paiements", label: "Paiements", badge: notifsNonLues, icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>` },
      ].map(link => {
        const isActive = currentPath === link.href || currentPath.startsWith(link.href + "/");
        return (
          <a href={link.href} class="relative flex-1 flex flex-col items-center justify-center gap-1 transition-all duration-200"
            style={isActive ? "color: #d4a762;" : "color: rgba(255,255,255,0.45);"}>
            {isActive && <span class="absolute top-0 left-1/2 -translate-x-1/2 w-8 h-0.5 rounded-full" style="background-color: #d4a762;"></span>}
            {link.badge > 0 && (
              <span class="absolute top-2 right-1/4 w-4 h-4 rounded-full flex items-center justify-center text-[10px] font-bold" style="background-color: #d4a762; color: #0b1f3a;">{link.badge > 9 ? "9+" : link.badge}</span>
            )}
            <span set:html={link.icon} />
            <span class="text-[10px] font-medium">{link.label}</span>
          </a>
        );
      })}
      <!-- Bouton "Plus" ouvre la sidebar -->
      <button id="mobile-menu-btn" class="flex-1 flex flex-col items-center justify-center gap-1 transition-all duration-200" style="color: rgba(255,255,255,0.45);">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        <span class="text-[10px] font-medium">Menu</span>
      </button>
    </nav>

    <script>
      const toggle = document.getElementById("menu-toggle");
      const mobileMenuBtn = document.getElementById("mobile-menu-btn");
      const sidebar = document.getElementById("sidebar-adherent");
      const overlay = document.getElementById("sidebar-overlay-adherent");
      function openSidebar() {
        sidebar?.classList.remove("-translate-x-full");
        overlay?.classList.remove("hidden");
      }
      toggle?.addEventListener("click", openSidebar);
      mobileMenuBtn?.addEventListener("click", openSidebar);
      overlay?.addEventListener("click", () => {
        sidebar?.classList.add("-translate-x-full");
        overlay?.classList.add("hidden");
      });
    </script>

  </body>
</html>
