---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import LogoJCBO from "../../components/ui/LogoJCBO.astro";
import { getCertificat } from "../../lib/store";

const mockCertificat = getCertificat();

const dateFormatee = new Date(mockCertificat.dateDelivrance).toLocaleDateString("fr-FR", {
  day: "numeric", month: "long", year: "numeric"
});
---

<AdherentMemberLayout titre="Mon certificat">

  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
    <div>
      <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Mon certificat</h2>
      <p class="text-sm text-gray-500 mt-1">Certificat de compétences MINDSET ENTREPRENEURIAL™</p>
    </div>
    <button
      id="btn-print"
      onclick="window.print()"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold transition hover:opacity-90 active:scale-[0.98] self-start"
      style="background-color: #0b1f3a; color: white;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
      </svg>
      Télécharger / Imprimer
    </button>
  </div>

  <!-- Certificat -->
  <div id="certificat-card" class="max-w-3xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden" style="border: 1px solid rgba(212,167,98,0.3);">

    <!-- Bandeau doré supérieur -->
    <div class="h-2 w-full" style="background: linear-gradient(90deg, #0b1f3a 0%, #d4a762 50%, #0b1f3a 100%);"></div>

    <div class="px-8 py-10 lg:px-14 lg:py-14">

      <!-- En-tête : logo + cabinet -->
      <div class="flex flex-col items-center text-center mb-8">
        <LogoJCBO size={72} />
        <p class="text-xs font-medium uppercase tracking-[0.25em] mt-4" style="color: #d4a762;">JCBO-CONSEIL</p>
        <p class="text-xs text-gray-400 tracking-widest mt-0.5">Stratégie · Mindset · Performance</p>
      </div>

      <!-- Séparateur doré -->
      <div class="flex items-center gap-4 mb-8">
        <div class="flex-1 h-px" style="background-color: rgba(212,167,98,0.3);"></div>
        <div class="w-1.5 h-1.5 rounded-full" style="background-color: #d4a762;"></div>
        <div class="flex-1 h-px" style="background-color: rgba(212,167,98,0.3);"></div>
      </div>

      <!-- Titre -->
      <div class="text-center mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold tracking-wide mb-2" style="color: #0b1f3a; font-family: 'Playfair Display', Georgia, serif;">
          CERTIFICAT DE COMPÉTENCES
        </h1>
        <p class="text-sm font-semibold tracking-[0.2em] uppercase" style="color: #d4a762;">
          MINDSET ENTREPRENEURIAL™ by JCBO-CONSEIL
        </p>
      </div>

      <!-- Corps du certificat -->
      <div class="text-center mb-8">
        <p class="text-sm text-gray-500 mb-4">Le cabinet <strong style="color: #0b1f3a;">JCBO-CONSEIL</strong> certifie que :</p>

        <div class="my-6 py-4" style="border-top: 1px solid #f1f3f5; border-bottom: 1px solid #f1f3f5;">
          <p class="text-2xl lg:text-3xl font-bold" style="color: #0b1f3a; font-family: 'Playfair Display', Georgia, serif;">
            {mockCertificat.nom}
          </p>
        </div>

        <p class="text-sm text-gray-500 mb-2">a suivi avec succès le programme de formation :</p>
        <p class="text-lg font-bold tracking-wide" style="color: #d4a762;">{mockCertificat.programme}</p>
        <p class="text-xs text-gray-400 mt-1">et a validé l'ensemble des modules, exercices et évaluations associés.</p>
      </div>

      <!-- Compétences développées -->
      <div class="mb-8 rounded-xl p-6" style="background-color: rgba(248,246,242,0.8); border: 1px solid rgba(212,167,98,0.15);">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: #0b1f3a;">Compétences développées</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
          {mockCertificat.competences.map((c) => (
            <div class="flex items-start gap-2.5">
              <div class="w-4 h-4 rounded flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(212,167,98,0.15);">
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <p class="text-xs text-gray-600 leading-relaxed">{c}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Attestation -->
      <div class="text-center mb-8">
        <p class="text-xs text-gray-500 leading-relaxed max-w-xl mx-auto">
          Ce certificat atteste de la capacité du participant à mobiliser les fondamentaux du
          <strong style="color: #0b1f3a;">MINDSET ENTREPRENEURIAL™</strong> dans un contexte professionnel,
          entrepreneurial ou managérial.
        </p>
      </div>

      <!-- Infos certificat + signature -->
      <div class="flex flex-col sm:flex-row justify-between items-start gap-6 pt-6" style="border-top: 1px solid #f1f3f5;">

        <div>
          <p class="text-xs text-gray-400 mb-1">Délivré le</p>
          <p class="text-sm font-semibold" style="color: #0b1f3a;">{dateFormatee}</p>
          <p class="text-xs text-gray-400 mt-3 mb-1">Numéro du certificat</p>
          <p class="text-sm font-mono font-semibold" style="color: #d4a762;">{mockCertificat.numero}</p>
        </div>

        <div class="text-center sm:text-right">
          <div class="w-32 h-px mb-3 sm:ml-auto" style="background-color: #0b1f3a;"></div>
          <p class="text-sm font-bold" style="color: #0b1f3a;">Jean-Christophe BOYANG-TSANG</p>
          <p class="text-xs text-gray-400 mt-0.5">Consultant en Business Development</p>
          <p class="text-xs text-gray-400">Fondateur du cabinet JCBO-CONSEIL</p>
        </div>

      </div>

    </div>

    <!-- Bandeau doré inférieur -->
    <div class="h-2 w-full" style="background: linear-gradient(90deg, #0b1f3a 0%, #d4a762 50%, #0b1f3a 100%);"></div>

  </div>

</AdherentMemberLayout>

<style>
  @media print {
    #btn-print { display: none !important; }
    #sidebar-adherent { display: none !important; }
    #sidebar-overlay-adherent { display: none !important; }
    header { display: none !important; }
    body { background: white !important; }
    main { padding: 0 !important; }
    #certificat-card {
      box-shadow: none !important;
      border-radius: 0 !important;
      max-width: 100% !important;
    }
  }
</style>
