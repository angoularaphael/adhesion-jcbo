---
import AdherentMemberLayout from "../../layouts/AdherentMemberLayout.astro";
import Card from "../../components/ui/Card.astro";
import { mockAdherent } from "../../data/mock";
---

<AdherentMemberLayout titre="Contact">

  <div class="mb-8">
    <h2 class="text-2xl font-bold" style="color: #0b1f3a;">Contact</h2>
    <p class="text-sm text-gray-500 mt-1">Une question ? L'équipe JCBO Conseil vous répond sous 24h.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <div class="lg:col-span-2">
      <Card>
        <h3 class="text-sm font-semibold mb-5" style="color: #0b1f3a;">Envoyer un message</h3>

        <form id="contact-form" class="flex flex-col gap-5">
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Sujet</label>
            <select id="contact-sujet" required class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762] bg-white" style="color: #0b1f3a;">
              <option value="">Choisir un sujet...</option>
              <option>Question sur mon adhésion</option>
              <option>Accès aux ressources</option>
              <option>Demande de renseignements</option>
              <option>Renouvellement</option>
              <option>Autre</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-medium text-gray-400 uppercase tracking-wide">Message</label>
            <textarea
              id="contact-message"
              rows="6"
              placeholder="Décrivez votre demande..."
              required
              class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm outline-none transition focus:border-[#d4a762] resize-none"
              style="color: #0b1f3a;"
            ></textarea>
          </div>

          <p id="contact-error" class="hidden text-xs text-red-400"></p>

          <button id="contact-submit" type="submit" class="self-start px-6 py-2.5 rounded-full text-sm font-semibold text-white transition hover:opacity-90 active:scale-[0.98] disabled:opacity-60" style="background-color: #0b1f3a;">
            Envoyer le message
          </button>
        </form>

        <div id="contact-success" class="hidden flex flex-col items-center justify-center py-10 gap-3 text-center">
          <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl" style="background-color: rgba(212,167,98,0.15); color: #d4a762;">✓</div>
          <p class="font-semibold" style="color: #0b1f3a;">Message envoyé !</p>
          <p class="text-sm text-gray-400">L'équipe JCBO Conseil vous répondra dans les meilleurs délais.</p>
        </div>
      </Card>
    </div>

    <div class="flex flex-col gap-4">
      <Card>
        <h3 class="text-sm font-semibold mb-4" style="color: #0b1f3a;">Coordonnées</h3>
        <div class="flex flex-col gap-4">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(212,167,98,0.1);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-xs text-gray-400 mb-0.5">E-mail</p>
              <a href="mailto:contact@jcbo-conseil.fr" class="text-sm font-medium hover:underline" style="color: #0b1f3a;">contact@jcbo-conseil.fr</a>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(212,167,98,0.1);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p class="text-xs text-gray-400 mb-0.5">Téléphone</p>
              <p class="text-sm font-medium" style="color: #0b1f3a;">01 23 45 67 89</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background-color: rgba(212,167,98,0.1);">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#d4a762" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div>
              <p class="text-xs text-gray-400 mb-0.5">Disponibilité</p>
              <p class="text-sm font-medium" style="color: #0b1f3a;">Lun – Ven, 9h – 18h</p>
            </div>
          </div>
        </div>
      </Card>

      <Card>
        <p class="text-xs text-gray-400 mb-1">Connecté en tant que</p>
        <p class="text-sm font-semibold" style="color: #0b1f3a;">{mockAdherent.prenom} {mockAdherent.nom}</p>
        <p class="text-xs text-gray-400 mt-0.5">{mockAdherent.email}</p>
      </Card>
    </div>

  </div>

  <script>
    document.getElementById("contact-form")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("contact-submit") as HTMLButtonElement;
      const errEl = document.getElementById("contact-error") as HTMLParagraphElement;
      btn.disabled = true;
      btn.textContent = "Envoi…";
      errEl.classList.add("hidden");

      const sujet = (document.getElementById("contact-sujet") as HTMLSelectElement).value;
      const message = (document.getElementById("contact-message") as HTMLTextAreaElement).value;

      if (!sujet) {
        errEl.textContent = "Veuillez choisir un sujet.";
        errEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Envoyer le message";
        return;
      }

      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ sujet, message }),
      });
      const data = await res.json();

      if (res.ok) {
        document.getElementById("contact-form")!.classList.add("hidden");
        document.getElementById("contact-success")!.classList.remove("hidden");
        return;
      }

      errEl.textContent = data.error || "Erreur lors de l'envoi. Réessayez.";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Envoyer le message";
    });
  </script>

</AdherentMemberLayout>
