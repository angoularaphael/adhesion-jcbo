---
import AdherentLayout from "../../layouts/AdherentLayout.astro";
import Badge from "../../components/ui/Badge.astro";
import { getActualites } from "../../lib/store";

const actualites = getActualites();
---

<AdherentLayout titre="Actualités">

  <div class="flex items-center justify-between mb-6">
    <p class="text-sm text-gray-400"><span id="count">{actualites.length}</span> article(s)</p>
    <button id="btn-nouvelle"
      class="flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold text-white transition-all duration-200 hover:opacity-90 active:scale-[0.98]"
      style="background-color: #0b1f3a;">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
      </svg>
      Nouvelle actualité
    </button>
  </div>

  <div class="flex flex-col gap-4" id="actu-list">
    {actualites.map((a) => (
      <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow duration-200 group actu-card" data-id={a.id} style="border: 1px solid #f1f3f5;">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-3">
              <Badge variant={a.statut === "Publié" ? "vert" : "gris"}>{a.statut}</Badge>
              <span class="text-xs text-gray-400">
                {new Date(a.date).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              </span>
            </div>
            <h3 class="text-base font-semibold mb-2 leading-snug" style="color: #0b1f3a;">{a.titre}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{a.contenu}</p>
          </div>
          <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
            <button class="btn-edit p-2 rounded-full hover:bg-blue-50 text-gray-400 hover:text-blue-500"
              data-id={a.id} data-titre={a.titre} data-contenu={a.contenu} data-statut={a.statut}
              title="Modifier">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </button>
            <button class="btn-delete p-2 rounded-full hover:bg-red-50 text-gray-400 hover:text-red-500"
              data-id={a.id} title="Supprimer">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
              </svg>
            </button>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Modal création -->
  <div id="modal-nouvelle" class="fixed inset-0 z-50 hidden items-center justify-center" style="background-color: rgba(0,0,0,0.5);">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-lg mx-4 animate-none">
      <h2 class="text-lg font-semibold mb-6" style="color: #0b1f3a;">Nouvelle actualité</h2>
      <form id="form-nouvelle" class="flex flex-col gap-5">
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Titre</label>
          <input id="input-titre" type="text" placeholder="Titre de l'actualité" required
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition" style="color: #0b1f3a;" />
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Contenu</label>
          <textarea id="input-contenu" rows="4" placeholder="Contenu de l'actualité..." required
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition resize-none" style="color: #0b1f3a;"></textarea>
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Statut</label>
          <select id="input-statut"
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition bg-white" style="color: #0b1f3a;">
            <option value="Brouillon">Brouillon</option>
            <option value="Publié">Publié</option>
          </select>
        </div>
        <p id="err-nouvelle" class="hidden text-xs text-red-400"></p>
        <div class="flex gap-3 justify-end pt-2">
          <button type="button" id="btn-annuler-nouvelle"
            class="px-5 py-2.5 rounded-full text-sm font-medium text-gray-500 hover:bg-gray-100 transition">Annuler</button>
          <button type="submit" id="btn-submit-nouvelle"
            class="px-5 py-2.5 rounded-full text-sm font-semibold text-white hover:opacity-90 transition disabled:opacity-60" style="background-color: #0b1f3a;">
            Publier
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal édition -->
  <div id="modal-edit" class="fixed inset-0 z-50 hidden items-center justify-center" style="background-color: rgba(0,0,0,0.5);">
    <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-lg mx-4">
      <h2 class="text-lg font-semibold mb-6" style="color: #0b1f3a;">Modifier l'actualité</h2>
      <form id="form-edit" class="flex flex-col gap-5">
        <input type="hidden" id="edit-id" />
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Titre</label>
          <input id="edit-titre" type="text" required
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition" style="color: #0b1f3a;" />
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Contenu</label>
          <textarea id="edit-contenu" rows="4" required
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition resize-none" style="color: #0b1f3a;"></textarea>
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-xs font-medium text-gray-400 uppercase tracking-widest">Statut</label>
          <select id="edit-statut"
            class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm outline-none focus:border-[#d4a762] transition bg-white" style="color: #0b1f3a;">
            <option value="Brouillon">Brouillon</option>
            <option value="Publié">Publié</option>
          </select>
        </div>
        <p id="err-edit" class="hidden text-xs text-red-400"></p>
        <div class="flex gap-3 justify-end pt-2">
          <button type="button" id="btn-annuler-edit"
            class="px-5 py-2.5 rounded-full text-sm font-medium text-gray-500 hover:bg-gray-100 transition">Annuler</button>
          <button type="submit" id="btn-submit-edit"
            class="px-5 py-2.5 rounded-full text-sm font-semibold text-white hover:opacity-90 transition disabled:opacity-60" style="background-color: #0b1f3a;">
            Enregistrer
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const modalNouvelle = document.getElementById("modal-nouvelle") as HTMLElement;
    const modalEdit = document.getElementById("modal-edit") as HTMLElement;

    // --- Modal nouvelle ---
    document.getElementById("btn-nouvelle")!.addEventListener("click", () => {
      (document.getElementById("form-nouvelle") as HTMLFormElement).reset();
      modalNouvelle.classList.replace("hidden", "flex");
    });
    document.getElementById("btn-annuler-nouvelle")!.addEventListener("click", () => modalNouvelle.classList.replace("flex", "hidden"));
    modalNouvelle.addEventListener("click", (e) => { if (e.target === modalNouvelle) modalNouvelle.classList.replace("flex", "hidden"); });

    document.getElementById("form-nouvelle")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("btn-submit-nouvelle") as HTMLButtonElement;
      const errEl = document.getElementById("err-nouvelle") as HTMLParagraphElement;
      btn.disabled = true;
      btn.textContent = "Envoi…";
      errEl.classList.add("hidden");

      const res = await fetch("/api/actualites", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          titre: (document.getElementById("input-titre") as HTMLInputElement).value,
          contenu: (document.getElementById("input-contenu") as HTMLTextAreaElement).value,
          statut: (document.getElementById("input-statut") as HTMLSelectElement).value,
        }),
      });
      const data = await res.json();

      if (res.ok) { window.location.reload(); return; }
      errEl.textContent = data.error || "Erreur lors de la création.";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Publier";
    });

    // --- Modal édition ---
    document.getElementById("btn-annuler-edit")!.addEventListener("click", () => modalEdit.classList.replace("flex", "hidden"));
    modalEdit.addEventListener("click", (e) => { if (e.target === modalEdit) modalEdit.classList.replace("flex", "hidden"); });

    document.querySelectorAll(".btn-edit").forEach((btn) => {
      btn.addEventListener("click", () => {
        const b = btn as HTMLButtonElement;
        (document.getElementById("edit-id") as HTMLInputElement).value = b.dataset.id!;
        (document.getElementById("edit-titre") as HTMLInputElement).value = b.dataset.titre!;
        (document.getElementById("edit-contenu") as HTMLTextAreaElement).value = b.dataset.contenu!;
        (document.getElementById("edit-statut") as HTMLSelectElement).value = b.dataset.statut!;
        modalEdit.classList.replace("hidden", "flex");
      });
    });

    document.getElementById("form-edit")!.addEventListener("submit", async (e) => {
      e.preventDefault();
      const btn = document.getElementById("btn-submit-edit") as HTMLButtonElement;
      const errEl = document.getElementById("err-edit") as HTMLParagraphElement;
      const id = (document.getElementById("edit-id") as HTMLInputElement).value;
      btn.disabled = true;
      btn.textContent = "Enregistrement…";
      errEl.classList.add("hidden");

      const res = await fetch(`/api/actualites/${id}`, {
        method: "PUT",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          titre: (document.getElementById("edit-titre") as HTMLInputElement).value,
          contenu: (document.getElementById("edit-contenu") as HTMLTextAreaElement).value,
          statut: (document.getElementById("edit-statut") as HTMLSelectElement).value,
        }),
      });
      const data = await res.json();

      if (res.ok) { window.location.reload(); return; }
      errEl.textContent = data.error || "Erreur lors de la modification.";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Enregistrer";
    });

    // --- Suppression ---
    document.querySelectorAll(".btn-delete").forEach((btn) => {
      btn.addEventListener("click", async () => {
        if (!confirm("Supprimer cette actualité définitivement ?")) return;
        const id = (btn as HTMLButtonElement).dataset.id!;
        const res = await fetch(`/api/actualites/${id}`, { method: "DELETE" });
        if (res.ok) window.location.reload();
      });
    });
  </script>

</AdherentLayout>
