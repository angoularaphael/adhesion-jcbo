{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/adherent/adhesion/?$",
			"dest": "_render"
		},
		{
			"src": "^/adherent/certificat/?$",
			"dest": "_render"
		},
		{
			"src": "^/adherent/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/adherent/profil/?$",
			"dest": "_render"
		},
		{
			"src": "^/adherent/ressources/?$",
			"dest": "_render"
		},
		{
			"src": "^/adherent/tableau-de-bord/?$",
			"dest": "_render"
		},
		{
			"src": "^/adherent/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/actualites/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/actualites/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/identifiants/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/messagerie/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/profil/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/actualites/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/identifiants/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/messagerie/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/profil/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/ressources/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/statistiques/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}